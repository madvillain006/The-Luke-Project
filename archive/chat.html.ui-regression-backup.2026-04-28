    document.querySelectorAll(".qbtn").forEach(btn => {
      btn.addEventListener("click", () => {
        const cmd = btn.dataset.cmd;
        input.value = cmd;
        input.focus();
        // auto-send for status (no argument needed)
        if (cmd === "/status" || cmd === "/verdict" || cmd === "/reset" || cmd === "/trading-mode" || cmd === "/review" || cmd === "/history" || cmd === "/entries ES") {
          send();
        }
      });
    });

