<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Luke</title>
  <style>
    :root {
      --bg:  #080c10;
      --bg2: #0d1117;
      --bg3: #0d1520;
      --b1:  #1a2332;
      --b2:  #2a3a4a;
      --dim: #4a5568;
      --med: #8a9ab0;
      --fg:  #c9d4e0;
      --green: #4ade80; --gbg: #0d1a0d; --gbr: #1a3a1a;
      --red:   #f87171; --rbg: #1a0d0d; --rbr: #4a1a1a;
      --yel:   #e2b96a; --ybg: #0d0900; --ybr: #4a3a00;
      --blu:   #60a5fa; --bbr: #1a2a4a;
      --pur:   #8b7cf8;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: var(--bg);
      color: var(--fg);
      font-family: -apple-system, "Segoe UI", sans-serif;
      display: flex;
      flex-direction: column;
      height: 100dvh;
      overflow: hidden;
      position: relative;
    }

    .has-tt { position: relative; }
    .tooltip { display: none; } /* JS handles positioning */

    /* JS tooltip ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â appended to body, never clipped */
    #js-tooltip {
      position: fixed;
      z-index: 99999;
      background: #1a1f2e;
      border: 1px solid #444;
      padding: 4px 9px;
      border-radius: 4px;
      font-size: 11px;
      color: #c9d4e0;
      pointer-events: none;
      white-space: nowrap;
      display: none;
      font-family: -apple-system, "Segoe UI", sans-serif;
    }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ TOP BAR ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #top-bar {
      height: 32px;
      display: flex;
      align-items: center;
      padding: 0 8px;
      border-bottom: 1px solid var(--b1);
      flex-shrink: 0;
      font-size: 11px;
      overflow: hidden;
      gap: 0;
    }
    .tb-seg {
      display: flex;
      align-items: center;
      gap: 4px;
      padding: 0 7px;
      height: 100%;
      white-space: nowrap;
    }
    .tb-seg:first-child { padding-left: 2px; }
    .tb-div { color: var(--b1); font-size: 15px; user-select: none; flex-shrink: 0; }
    .tb-lbl { color: var(--dim); font-size: 10px; letter-spacing: 0.3px; }

    #tb-dot { font-size: 9px; color: var(--green); }
    #tb-dot.err { color: var(--red); }
    #tb-luke-text { color: var(--med); letter-spacing: 1px; font-size: 11px; }

    #chip-mode {
      font-size: 9px;
      letter-spacing: 1px;
      padding: 1px 5px;
      border-radius: 3px;
      border: 1px solid var(--b1);
      color: var(--dim);
      cursor: default;
    }
    #chip-mode.paper { color: var(--yel); border-color: var(--ybr); background: var(--ybg); }
    #chip-mode.live  { color: var(--green); border-color: var(--gbr); background: var(--gbg); }

    #tb-market-val { color: var(--dim); }
    #tb-market-val.open    { color: var(--green); }
    #tb-market-val.prepost { color: var(--yel); }

    #tb-regime-val { color: var(--blu); }
    #tb-regime-val.risk-on  { color: var(--green); }
    #tb-regime-val.risk-off { color: var(--red); }

    .tb-px { font-family: "Courier New", monospace; font-size: 11px; color: var(--dim); gap: 5px; display: flex; }

    #tb-trades-val { color: var(--dim); }

    .tb-killbtn {
      font-size: 9px;
      padding: 1px 4px;
      border-radius: 3px;
      cursor: pointer;
      background: transparent;
      letter-spacing: 0.3px;
    }
    #look-btn { border: 1px solid var(--b1); color: var(--blu); font-size: 9px; padding: 1px 4px; border-radius: 3px; cursor: pointer; background: transparent; }
    #look-btn:hover { background: var(--bg3); }

    /* hidden legacy chips (keep in DOM for JS) */
    #chip-pnl, #chip-pos, #chip-apex, #chip-arch,
    #chip-sweep, #chip-conn, #chip-canary { display: none !important; }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ MESSAGES ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #messages {
      flex: 1;
      overflow-y: auto;
      padding: 6px 8px;
      display: flex;
      flex-direction: column;
      gap: 3px;
      min-height: 0;
      position: relative;
    }
    #messages::-webkit-scrollbar { width: 3px; }
    #messages::-webkit-scrollbar-thumb { background: var(--b1); border-radius: 2px; }

    .msg-row { display: flex; align-items: flex-end; gap: 5px; }
    .msg-row.user   { flex-direction: row-reverse; }
    .msg-row.luke { flex-direction: row; }

    .bubble {
      max-width: 85%;
      padding: 5px 9px;
      border-radius: 4px;
      font-size: 13px;
      line-height: 1.5;
      white-space: pre-wrap;
      word-break: break-word;
      background: var(--bg2);
      border: 1px solid var(--b1);
      border-left-width: 2px;
      color: var(--fg);
    }
    .bubble.user   { background: var(--gbg); border-color: var(--gbr); color: var(--green); border-left-width: 1px; }
    .bubble.luke { border-left-color: #2a3a4a; }
    .bubble.setup  { border-left-color: var(--green); }
    .bubble.skip   { border-left-color: var(--red); }
    .bubble.weak   { border-left-color: var(--yel); }
    .bubble.alert  { background: #1a0d00; border-left-color: var(--yel); color: var(--yel); }
    .bubble.vision { background: #0a0d1a; border-left-color: var(--blu); }
    .bubble img    { max-width: 200px; max-height: 140px; display: block; border-radius: 2px; border: 1px solid var(--b1); }

    .msg-ts { font-size: 10px; color: var(--dim); flex-shrink: 0; padding-bottom: 3px; }

    .thinking { color: var(--dim); font-size: 10px; letter-spacing: 2px; padding: 3px 0; align-self: flex-start; }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ MORNING CHECKLIST ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #morning-checklist {
      position: absolute;
      top: 6px;
      right: 8px;
      z-index: 50;
      background: var(--bg2);
      border: 1px solid var(--b1);
      border-radius: 4px;
      padding: 6px 9px;
      min-width: 188px;
    }
    #morning-checklist.hidden { display: none; }
    #mc-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
    #mc-title { font-size: 9px; letter-spacing: 1.5px; color: var(--dim); }
    #mc-close { background: transparent; border: none; color: var(--dim); cursor: pointer; font-size: 13px; line-height: 1; padding: 0; }
    #mc-close:hover { color: var(--fg); }
    .mc-item { display: flex; align-items: center; gap: 6px; padding: 2px 0; }
    .mc-check { font-size: 11px; color: var(--dim); width: 12px; flex-shrink: 0; }
    .mc-item.done .mc-check { color: var(--green); }
    .mc-cmd { font-family: "Courier New", monospace; font-size: 11px; color: var(--blu); }
    .mc-item.done .mc-cmd { color: var(--green); }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ BOTTOM BAR ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #bottom-bar {
      min-height: 86px;
      flex-shrink: 0;
      border-top: 1px solid var(--b1);
      background: var(--bg);
      display: flex;
      flex-direction: column;
      padding: 7px 8px;
      gap: 6px;
    }
    #input-row { display: flex; gap: 6px; }
    #input {
      flex: 1;
      background: var(--bg2);
      border: 1px solid var(--b1);
      color: var(--fg);
      padding: 5px 10px;
      font-family: inherit;
      font-size: 13px;
      outline: none;
      border-radius: 4px;
      min-width: 0;
      height: 32px;
    }
    #input:focus { border-color: var(--b2); }
    #send {
      background: var(--yel);
      border: none;
      color: var(--bg);
      padding: 0 12px;
      height: 32px;
      font-family: inherit;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      cursor: pointer;
      border-radius: 4px;
      flex-shrink: 0;
    }
    #send:disabled { opacity: 0.5; cursor: wait; }
    #quick-btns { display: flex; gap: 4px; flex-wrap: wrap; overflow: visible; }
    .qbtn {
      flex: 1 1 auto;
      background: transparent;
      border: 1px solid var(--b1);
      color: var(--dim);
      padding: 4px 6px;
      font-family: "Courier New", monospace;
      font-size: 11px;
      cursor: pointer;
      border-radius: 4px;
      white-space: nowrap;
      overflow: hidden;
      position: relative;
    }
    .qbtn:hover { background: var(--bg3); color: var(--fg); border-color: var(--b2); }

    @media (max-width: 1000px) {
      .bubble { max-width: 95%; }
      #tb-prices { display: none; }
    }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ WIDGET MODE (ÃƒÂ¢Ã¢â‚¬Â°Ã‚Â¤500px) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    @media (max-width: 500px) {
      .qbtn { font-size: 11px; padding: 4px 6px; }
      .tb-lbl { display: none; }
      .tb-div { display: none; }
      .tb-seg { padding: 0 3px; }
      #tb-luke-text { font-size: 10px; letter-spacing: 0; }
      #tb-trades-val { font-size: 9px; }
      .bubble { font-size: 12px; padding: 4px 7px; }
      #top-bar { gap: 0; }
      #look-btn { display: none; }
    }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ STAGED TRADE OVERLAY ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #pending-trade {
      position: absolute;
      top: 32px; left: 0; right: 0; bottom: 0;
      z-index: 100;
      background: #0a0800;
      display: none;
      flex-direction: column;
    }
    #pending-trade.visible { display: flex; }
    #pt-chart { height: 162px; flex-shrink: 0; border-bottom: 1px solid #1a1200; position: relative; overflow: hidden; }
    #pt-chart-inner { height: 162px; }
    .tradingview-widget-container,
    .tradingview-widget-container__widget { height: 162px; }
    #pt-price-labels {
      position: absolute; right: 6px; top: 0; bottom: 0;
      display: flex; flex-direction: column; justify-content: space-between;
      padding: 18px 0 20px; pointer-events: none; z-index: 10;
    }
    .price-label { font-size: 9px; letter-spacing: 1px; padding: 2px 4px; border-radius: 2px; }
    .price-label.target { color: var(--green); background: rgba(10,30,10,0.85); border: 1px solid var(--gbr); }
    .price-label.entry  { color: #e2e8f0; background: rgba(10,15,25,0.85); border: 1px solid var(--b2); }
    .price-label.stop   { color: var(--red); background: rgba(30,10,10,0.85); border: 1px solid var(--rbr); }
    #pt-body { padding: 8px 10px 6px; flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
    #pt-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .pt-label  { font-size: 8px; letter-spacing: 2px; color: var(--yel); }
    #pt-signal { font-size: 12px; color: #f5dfa0; letter-spacing: 0.5px; margin-bottom: 2px; }
    #pt-meta   { font-size: 10px; color: #8a7a4a; margin-bottom: 3px; }
    #pt-reason { font-size: 10px; color: #a09060; line-height: 1.4; margin-bottom: 6px; }
    #pt-actions { display: flex; gap: 8px; align-items: center; }
    .countdown-svg { width: 34px; height: 34px; }
    .ring-bg       { fill: none; stroke: var(--b1); stroke-width: 3.5; }
    .ring-progress { fill: none; stroke: var(--yel); stroke-width: 3.5; stroke-dasharray: 100 100; stroke-dashoffset: 25; stroke-linecap: round; transition: stroke-dasharray 1s linear; }
    .ring-text { font-size: 8px; font-family: inherit; fill: var(--fg); text-anchor: middle; dominant-baseline: middle; }
    #execute-btn { background: #1a3a1a; border: 1px solid var(--green); color: var(--green); padding: 6px 16px; font-family: inherit; font-size: 10px; font-weight: 700; letter-spacing: 2px; cursor: pointer; border-radius: 4px; }
    #execute-btn:hover    { background: var(--green); color: var(--bg); }
    #execute-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    #skip-btn { background: transparent; border: 1px solid #4a2a2a; color: var(--red); padding: 6px 10px; font-family: inherit; font-size: 10px; letter-spacing: 1.5px; cursor: pointer; border-radius: 4px; }
    #skip-btn:hover { border-color: var(--red); }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ TOAST ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #toast {
      position: absolute;
      bottom: 108px; left: 8px; right: 8px;
      background: var(--bg3);
      border: 1px solid #1a3a5a;
      color: var(--fg);
      font-size: 10px;
      padding: 6px 10px;
      border-radius: 6px;
      z-index: 200;
      display: none;
      white-space: pre-wrap;
      max-height: 80px;
      overflow: hidden;
    }
    #toast.show { display: block; }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ DRAG OVERLAY ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #drag-overlay {
      position: absolute; inset: 0; z-index: 300;
      background: rgba(8,12,16,0.88);
      display: none; align-items: center; justify-content: center;
      font-size: 16px; letter-spacing: 3px; color: var(--blu);
      border: 2px dashed var(--blu); pointer-events: none;
    }
    #drag-overlay.show { display: flex; }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ BOOT MODAL ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #boot-modal { position: absolute; inset: 0; z-index: 500; background: rgba(8,12,16,0.95); display: none; flex-direction: column; align-items: center; justify-content: center; padding: 20px; }
    #boot-modal.show { display: flex; }
    #boot-modal-inner { background: var(--bg2); border: 1px solid var(--rbr); border-radius: 6px; padding: 16px; width: 100%; max-width: 340px; }
    #boot-modal h3 { font-size: 11px; letter-spacing: 2px; color: var(--red); margin-bottom: 10px; }
    #boot-modal ul { list-style: none; font-size: 10px; line-height: 1.8; }
    #boot-modal li.red    { color: var(--red); }
    #boot-modal li.yellow { color: var(--yel); }
    #boot-modal li.green  { color: var(--green); }
    #boot-modal-close { margin-top: 12px; background: transparent; border: 1px solid var(--b2); color: var(--fg); padding: 4px 12px; font-family: inherit; font-size: 10px; letter-spacing: 1px; cursor: pointer; border-radius: 4px; }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ PANIC MODAL ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #panic-modal { position: absolute; inset: 0; z-index: 600; background: rgba(8,12,16,0.95); display: none; align-items: center; justify-content: center; }
    #panic-modal.show { display: flex; }
    #panic-inner { background: #1a0000; border: 1px solid var(--red); border-radius: 6px; padding: 16px; max-width: 260px; text-align: center; }
    #panic-inner p { font-size: 11px; letter-spacing: 1px; color: var(--red); margin-bottom: 12px; }
    #panic-confirm { background: var(--red); border: none; color: var(--bg); padding: 6px 16px; font-family: inherit; font-size: 10px; font-weight: 700; letter-spacing: 2px; cursor: pointer; border-radius: 4px; margin-right: 8px; }
    #panic-cancel  { background: transparent; border: 1px solid var(--b2); color: var(--fg); padding: 6px 12px; font-family: inherit; font-size: 10px; cursor: pointer; border-radius: 4px; letter-spacing: 1px; }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ METRICS PANEL ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #metrics-panel { position: absolute; top: 32px; left: 0; right: 0; bottom: 0; z-index: 91; background: var(--bg); display: none; flex-direction: column; }
    #metrics-panel.visible { display: flex; }
    #mp-header { display: flex; align-items: center; justify-content: space-between; padding: 5px 10px; border-bottom: 1px solid var(--b1); flex-shrink: 0; }
    #mp-title { font-size: 10px; letter-spacing: 2px; color: #38bdf8; }
    #mp-close { background: transparent; border: 1px solid var(--b1); color: var(--dim); font-size: 11px; padding: 1px 6px; border-radius: 4px; cursor: pointer; }
    #mp-close:hover { color: var(--fg); border-color: var(--b2); }
    #mp-controls { display: flex; gap: 6px; align-items: center; padding: 5px 10px; border-bottom: 1px solid var(--b1); flex-shrink: 0; }
    #mp-hours-input { width: 44px; background: var(--bg2); border: 1px solid var(--b1); color: var(--fg); padding: 2px 5px; font-family: inherit; font-size: 10px; border-radius: 4px; outline: none; text-align: center; }
    #mp-load-btn, #mp-copy-btn { background: #0d1a2a; border: 1px solid #38bdf8; color: #38bdf8; padding: 2px 10px; font-family: inherit; font-size: 9px; font-weight: 700; letter-spacing: 1.5px; cursor: pointer; border-radius: 4px; }
    #mp-load-btn:hover, #mp-copy-btn:hover { background: #38bdf8; color: var(--bg); }
    #mp-load-btn:disabled { opacity: 0.4; cursor: wait; }
    #mp-copy-btn { border-color: #64748b; color: #64748b; }
    #mp-copy-btn:hover { background: #64748b; color: var(--bg); }
    #mp-body { flex: 1; overflow-y: auto; padding: 8px 10px; }
    .mp-section { margin-bottom: 12px; }
    .mp-section-label { font-size: 9px; letter-spacing: 2px; color: var(--dim); margin-bottom: 5px; }
    .mp-row { display: flex; justify-content: space-between; align-items: baseline; padding: 2px 0; border-bottom: 1px solid var(--bg2); }
    .mp-key { font-size: 9px; letter-spacing: 1px; color: var(--dim); }
    .mp-val { font-size: 11px; color: var(--fg); font-variant-numeric: tabular-nums; }
    .mp-val.pos { color: var(--green); } .mp-val.neg { color: var(--red); } .mp-val.warn { color: #fbbf24; }
    .mp-critical-item { font-size: 9px; color: var(--red); letter-spacing: 0.5px; padding: 2px 0; border-bottom: 1px solid var(--bg2); }
    .mp-critical-ts { color: var(--dim); margin-right: 6px; }
    #mp-status { font-size: 9px; color: var(--dim); letter-spacing: 1px; padding: 2px 0; min-height: 13px; }

    /* ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ LUKE PANEL ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ */
    #luke-panel { position: absolute; top: 32px; left: 0; right: 0; bottom: 0; z-index: 90; background: var(--bg); display: none; flex-direction: column; }
    #luke-panel.visible { display: flex; }
    #lp-header { display: flex; align-items: center; justify-content: space-between; padding: 5px 10px; border-bottom: 1px solid var(--b1); flex-shrink: 0; }
    #lp-title { font-size: 10px; letter-spacing: 2px; color: var(--pur); }
    #lp-close { background: transparent; border: 1px solid var(--b1); color: var(--dim); font-size: 11px; padding: 1px 6px; border-radius: 4px; cursor: pointer; }
    #lp-close:hover { color: var(--fg); border-color: var(--b2); }
    #lp-body { flex: 1; overflow-y: auto; padding: 8px 10px; display: flex; flex-direction: column; gap: 12px; }
    .lp-section-label { font-size: 9px; letter-spacing: 2px; color: var(--dim); margin-bottom: 5px; }
    .lp-draft { background: var(--bg2); border: 1px solid var(--b1); border-radius: 6px; padding: 7px 10px; margin-bottom: 4px; }
    .lp-draft-meta { color: var(--dim); font-size: 9px; letter-spacing: 0.5px; margin-bottom: 3px; }
    .lp-draft-values { color: var(--fg); font-size: 11px; margin-bottom: 5px; line-height: 1.6; }
    .lp-draft-btns { display: flex; gap: 6px; }
    .lp-confirm-btn { background: var(--gbg); border: 1px solid var(--gbr); color: var(--green); padding: 2px 10px; font-family: inherit; font-size: 9px; letter-spacing: 1.5px; cursor: pointer; border-radius: 4px; }
    .lp-confirm-btn:hover { background: var(--green); color: var(--bg); }
    .lp-confirm-btn:disabled { opacity: 0.4; cursor: wait; }
    .lp-reject-btn { background: transparent; border: 1px solid #4a2a2a; color: var(--red); padding: 2px 10px; font-family: inherit; font-size: 9px; letter-spacing: 1.5px; cursor: pointer; border-radius: 4px; }
    .lp-reject-btn:hover { border-color: var(--red); }
    .lp-reject-btn:disabled { opacity: 0.4; cursor: wait; }
    .lp-empty { color: var(--dim); font-size: 10px; letter-spacing: 1px; padding: 2px 0; }
    .lp-flags { color: var(--red); font-size: 9px; letter-spacing: 1px; margin-top: 4px; }
    .lp-row { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
    .lp-label { font-size: 9px; letter-spacing: 1.5px; color: var(--dim); width: 44px; flex-shrink: 0; }
    .lp-input { flex: 1; background: var(--bg2); border: 1px solid var(--b1); color: var(--fg); padding: 3px 7px; font-family: inherit; font-size: 11px; border-radius: 4px; outline: none; min-width: 0; }
    .lp-input:focus { border-color: var(--b2); }
    .lp-select { flex: 1; background: var(--bg2); border: 1px solid var(--b1); color: var(--fg); padding: 3px 7px; font-family: inherit; font-size: 11px; border-radius: 4px; outline: none; min-width: 0; }
    #lp-submit { margin-top: 4px; background: #1a1a3a; border: 1px solid var(--pur); color: var(--pur); padding: 4px 14px; font-family: inherit; font-size: 9px; font-weight: 700; letter-spacing: 2px; cursor: pointer; border-radius: 4px; }
    #lp-submit:hover { background: var(--pur); color: var(--bg); }
    #lp-submit:disabled { opacity: 0.4; cursor: wait; }
    #lp-form-result { font-size: 10px; margin-top: 5px; min-height: 14px; }
  </style>
</head>
