    const mcState = { balance: false, saty: false, dubz: false, heatmap: false, verdict: false };

    function checkMC(text) {
      if (/^\/balance\b/i.test(text)) { mcState.balance = true; }
      if (/^\/saty\b/i.test(text))    { mcState.saty = true; }
      if (/^\/dubz/i.test(text))       { mcState.dubz = true; }
      if (/^\/heatmap/i.test(text))    { mcState.heatmap = true; }
      if (/^\/verdict/i.test(text))    { mcState.verdict = true; }
      updateMC();
    }

    function updateMC() {
      ["balance", "saty", "dubz", "heatmap", "verdict"].forEach(key => {
        const el = document.getElementById("mc-" + key);
        if (!el) return;
        if (mcState[key]) {
          el.classList.add("done");
          el.querySelector(".mc-check").textContent = "OK";
        }
      });
      if (mcState.balance && mcState.saty && mcState.dubz && mcState.heatmap && mcState.verdict) {
        setTimeout(() => document.getElementById("morning-checklist").classList.add("hidden"), 1200);
      }
    }

    document.getElementById("mc-close").addEventListener("click", () => {
      document.getElementById("morning-checklist").classList.add("hidden");
    });

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ STAGED TRADE ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    const pendingTrade = document.getElementById("pending-trade");
    const executeBtn   = document.getElementById("execute-btn");
    const skipBtn      = document.getElementById("skip-btn");
    let countdownInterval = null;

    function showPending(data) {
      const s = data.signal;
      const ticker = s.ticker || "MNQ";
      document.getElementById("pt-signal").textContent =
        s.direction + " " + ticker + "  Ãƒâ€šÃ‚Â·  E:" + s.entry + "  S:" + s.stop + "  T:" + s.target;
      const confluencePart = s.confluence_score != null
        ? "  Ãƒâ€šÃ‚Â·  CONF:" + s.confluence_score + " [" + (s.confluence_confidence || "?") + "]"
        : "";
      const sourcesPart = s.confluence_sources && s.confluence_sources.length
        ? "  src:" + s.confluence_sources.join("+")
        : "";
      document.getElementById("pt-meta").textContent =
        "Risk: $" + data.risk_dollars + "  Ãƒâ€šÃ‚Â·  R:R " + data.rr + ":1" + confluencePart + sourcesPart;
      document.getElementById("pt-reason").textContent = s.reason || "";
      document.getElementById("lbl-target").textContent = "T " + s.target;
      document.getElementById("lbl-entry").textContent  = "E " + s.entry;
      document.getElementById("lbl-stop").textContent   = "S " + s.stop;
      pendingTrade.classList.add("visible");
      loadTVWidget(ticker);
      startCountdown(data.seconds_left);
    }

    function hidePending() {
      pendingTrade.classList.remove("visible");
      if (countdownInterval) { clearInterval(countdownInterval); countdownInterval = null; }
      document.getElementById("pt-chart-inner").innerHTML = "";
    }

    function loadTVWidget(ticker) {
      const container = document.getElementById("pt-chart-inner");
      container.innerHTML = "";
      const wrapper = document.createElement("div");
      wrapper.className = "tradingview-widget-container";
      const inner = document.createElement("div");
      inner.className = "tradingview-widget-container__widget";
      wrapper.appendChild(inner);
      const script = document.createElement("script");
      script.type = "text/javascript";
      script.src = "https://s3.tradingview.com/external-embedding/embed-widget-advanced-chart.js";
      script.async = true;
      script.text = JSON.stringify({
        autosize: false, width: "100%", height: 162,
        symbol: ticker === "MES" ? "CME_MINI:MES1!" : "CME_MINI:MNQ1!",
        interval: "5", timezone: "America/New_York", theme: "dark", style: "1", locale: "en",
        hide_top_toolbar: true, hide_legend: true, allow_symbol_change: false,
        calendar: false, hide_volume: true, support_host: "https://www.tradingview.com"
      });
      wrapper.appendChild(script);
      container.appendChild(wrapper);
    }

    function startCountdown(seconds) {
      if (countdownInterval) clearInterval(countdownInterval);
      const total = 300;
      let s = seconds;
      const textEl = document.getElementById("pt-countdown-text");
      const ringEl = document.getElementById("pt-ring");
      function tick() {
        if (s <= 0) { hidePending(); return; }
        textEl.textContent = Math.floor(s / 60) + ":" + (s % 60).toString().padStart(2, "0");
        ringEl.style.strokeDasharray = ((s / total) * 100) + " 100";
        ringEl.style.stroke = s < 60 ? "#f87171" : "#e2b96a";
        s--;
      }
      tick();
      countdownInterval = setInterval(tick, 1000);
    }

    async function checkPendingSignal() {
      try {
        const r = await fetch(BASE + "/agent/autonomous/pending");
        const d = await r.json();
        if (d.pending) showPending(d);
        else hidePending();
      } catch {}
    }
    checkPendingSignal();
    setInterval(checkPendingSignal, 15000);

    executeBtn.addEventListener("click", async () => {
      const modeChip = document.getElementById("chip-mode");
      if (!modeChip || modeChip.className === "off" || modeChip.textContent === "OFF") {
        hidePending();
        toast("02B is OFF ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â enter this trade manually in Tradovate.", 5000);
        addMessage("assistant", "Enter this trade manually in Tradovate ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â 02B is OFF and will not send orders.", "alert");
        return;
      }
      const stateClass = document.getElementById("ribbon-state").className || "regulated";
      if (stateClass === "rule_break") {
        logIntervention("rule_break", "execute blocked");
        toast("Rule break detected ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â execute disabled.", 4000);
        return;
      }
      if (stateClass === "spiraling") {
        const now = Date.now();
        if (now - executeFirstTap < 1000) {
          logIntervention("spiraling", "double-confirmed execute");
        } else {
          executeFirstTap = now;
          toast("Spiraling ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â tap EXECUTE again within 1s to confirm.", 3000);
          return;
        }
      }
      executeBtn.disabled = true; executeBtn.textContent = "...";
      try {
        const r = await fetch(BASE + "/agent/autonomous/execute-staged", { method: "POST", headers: { "Content-Type": "application/json" }, body: "{}" });
        const d = await r.json();
        hidePending();
        if (d.executed === false) addMessage("assistant", "Execute failed: " + d.reason, "alert");
      } catch { addMessage("assistant", "Execute error.", "alert"); }
      executeBtn.disabled = false; executeBtn.textContent = "EXECUTE";
    });

    async function logIntervention(state, action) {
      try { await fetch(BASE + "/luke/log-intervention", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ state, action }) }); } catch {}
    }

    skipBtn.addEventListener("click", async () => {
      try { await fetch(BASE + "/agent/autonomous/skip-staged", { method: "POST", headers: { "Content-Type": "application/json" }, body: "{}" }); } catch {}
      hidePending();
    });

    document.addEventListener("keydown", e => {
      if (!pendingTrade.classList.contains("visible")) return;
      if ((e.key === "e" || e.key === "E") && !executeBtn.disabled) executeBtn.click();
      if (e.key === "s" || e.key === "S") skipBtn.click();
    });

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ WEBSOCKET ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    ws.onmessage = (event) => {
      try {
        const data = JSON.parse(event.data);
        if (data.type === "staged_trade") {
          showPending(data);
          if (data.canary) {
            const chip = document.getElementById("chip-canary");
            chip.textContent = "CANARY";
            setTimeout(() => { chip.textContent = ""; }, 35000);
          }
        }
        if (data.type === 'staged_trade' && window.electronAPI) {
            window.electronAPI.showTradePopup(data.trade || data)
        }
        else if (data.type === "status_update") updateChips(data);
        else if (data.type === "levels_warning") {
          addMessage("assistant", data.message, "alert");
          const sp = document.getElementById("sp-levels");
          if (sp) { sp.textContent = "LEVELS: NONE"; sp.className = "sp-item err"; }
          refreshStatusPanel();
        }
        else if (data.type === "notification") {
          addMessage("assistant", data.message, "alert");
          if (/02B|KILL|PAPER|LIVE|CLOSED/.test(data.message)) syncStatus();
        }
        else if (data.type === "kat_alert") {
          addMessage("assistant", data.reply, "kat-alert");
        }
        else if (data.type === 'kat_vision') {
          const levels = (data.levels || []).join(', ');
          const msg = 'ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã‚Â¸ ' + data.analyst + ' chart: ' +
            (data.ticker || '?') + ' ' + data.bias +
            (levels ? ' | levels: ' + levels : '') +
            (data.notes ? '\n' + data.notes : '');
          addMessage('kat', msg, 'kat-vision');
        }
      } catch (e) { console.error('[ws:onmessage] parse error:', e.message, event.data?.slice(0, 80)); }
    };
    } // end initWs

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ STATE INDICATOR ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    function updateStateIndicator(state) {
      if (!state) return;
      const el = document.getElementById("ribbon-state");
      el.className = state === "regulated" ? "" : state;
      const labels = { regulated: "ONLINE", stressed: "STRESSED", spiraling: "SPIRALING", rule_break: "RULE BREAK" };
      el.textContent = labels[state] || "ONLINE";
    }

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ MESSAGES ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    function nowTs() {
      const d = new Date();
      return d.getHours().toString().padStart(2,"0") + ":" + d.getMinutes().toString().padStart(2,"0");
    }

    function detectBubbleType(text, type) {
      if (type === "alert")  return "alert";
      if (type === "vision") return "vision";
      if (/^SETUP[:\s]/i.test(text))  return "setup";
      if (/^SKIP[:\s]/i.test(text))   return "skip";
      if (/^WEAK[:\s]/i.test(text))   return "weak";
      return "luke";
    }

    function addMessage(role, text, type) {
      const row = document.createElement("div");
      row.className = "msg-row " + (role === "user" ? "user" : "luke");

      const bubble = document.createElement("div");
      const bType = role === "user" ? "user" : detectBubbleType(text, type);
      bubble.className = "bubble " + bType;
      bubble.textContent = text;
      row.appendChild(bubble);

      const ts = document.createElement("span");
      ts.className = "msg-ts";
      ts.textContent = nowTs();
      row.appendChild(ts);

      messages.appendChild(row);
      messages.scrollTop = messages.scrollHeight;
    }

    function addImageMessage(dataUrl) {
      const row = document.createElement("div");
      row.className = "msg-row user";
      const bubble = document.createElement("div");
      bubble.className = "bubble user";
      const img = document.createElement("img");
      img.src = dataUrl;
      bubble.appendChild(img);
      row.appendChild(bubble);
      const ts = document.createElement("span");
      ts.className = "msg-ts";
      ts.textContent = nowTs();
      row.appendChild(ts);
      messages.appendChild(row);
      messages.scrollTop = messages.scrollHeight;
    }

    function showThinking(text) {
      const div = document.createElement("div");
      div.className = "thinking"; div.id = "thinking";
      div.textContent = text || "THINKING...";
      messages.appendChild(div);
      messages.scrollTop = messages.scrollHeight;
    }

    function hideThinking() {
      const t = document.getElementById("thinking");
      if (t) t.remove();
    }

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ IMAGE PASTE / DROP ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    async function handleImageBlob(blob, mimeType) {
      const reader = new FileReader();
      reader.onload = async (evt) => {
        const dataUrl = evt.target.result;
        const base64  = dataUrl.split(",")[1];
        addImageMessage(dataUrl);
        const question = input.value.trim();
        input.value = "";
        showThinking("ANALYZING...");
        sendBtn.disabled = true;
        try {
          let r, d;
          if (!question) {
            // Image-only paste: route through /chat so handlePasteAccumulate
            // can update daily context, check the checklist, and fire verdict.
            r = await fetch(BASE + "/chat", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ image: base64, message: "" })
            });
            d = await r.json();
          } else {
            // Image + text: vision query
            r = await fetch(BASE + "/see-image", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ image: base64, mime_type: mimeType, question })
            });
            d = await r.json();
          }
          hideThinking();
          addMessage("assistant", d.reply || d.error || "No response.", "vision");
        } catch {
          hideThinking();
          addMessage("assistant", "Image analysis failed.");
        }
        sendBtn.disabled = false;
        input.focus();
      };
      reader.readAsDataURL(blob);
    }

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ PASTE DETECTION ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬
    const PASTE_ANALYST_RULES = [
      { re: /\b(ximes|ximestrades|xi[mn]es|followthewhiterabblt)\b/i, command: '/alert',   analyst: 'ximes' },
      { re: /\b(bobby|followtherabbit|spx[_ -]?coms)\b/i,             command: '/heatmap', analyst: 'bobby' },
      { re: /\b(richy|richydubz|richyd)\b/i,                          command: '/dubz',    analyst: 'richy' },
    ];
    const PASTE_DISCORD_PREFIX = /^[\s\S]*?(?:\[\d{1,2}:\d{2}\s*(?:AM|PM)\][^\n,]*,\s*:|[^\n]+ ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â Today at \d{1,2}:\d{2}\s*(?:AM|PM)\s*\n?)/i;
    const PASTE_OPTION_RE     = /\b[A-Z]{1,5}\s+\d{3,5}[CP]\b/i;
    const PASTE_HEATMAP_RE    = /\b(king node|air pocket|trinity)\b/i;

    function detectPasteIntent(text, hasImage) {
      if (hasImage) return { command: '/heatmap', cleanedText: text, detectedAnalyst: 'bobby' };
      const sample = text.slice(0, 200);
      for (const r of PASTE_ANALYST_RULES) {
        if (r.re.test(sample)) return { command: r.command, cleanedText: text.replace(PASTE_DISCORD_PREFIX, '').trimStart(), detectedAnalyst: r.analyst };
      }
      if (PASTE_OPTION_RE.test(sample))   return { command: '/alert',   cleanedText: text.replace(PASTE_DISCORD_PREFIX, '').trimStart(), detectedAnalyst: null };
      if (PASTE_HEATMAP_RE.test(sample))  return { command: '/heatmap', cleanedText: text.replace(PASTE_DISCORD_PREFIX, '').trimStart(), detectedAnalyst: null };
      return { command: null, cleanedText: text, detectedAnalyst: null };
    }

    const pasteHint = document.getElementById("paste-hint");
    let pasteHintTimer = null;
    function showPasteHint(msg) {
      pasteHint.textContent = msg;
      pasteHint.style.display = "block";
      clearTimeout(pasteHintTimer);
      pasteHintTimer = setTimeout(() => { pasteHint.style.display = "none"; }, 4000);
    }

    document.addEventListener("paste", (e) => {
      const items = Array.from(e.clipboardData?.items || []);
      const imageItem = items.find(item => item.type.startsWith("image/"));
      if (imageItem) {
        e.preventDefault();
        handleImageBlob(imageItem.getAsFile(), imageItem.type);
        return;
      }
      // text paste detection (only when input is focused or no element is focused)
      const textItem = items.find(item => item.type === "text/plain");
      if (!textItem) return;
      textItem.getAsString(text => {
        if (!text || text.length < 10) return;
        if (document.activeElement !== input) return;
        const { command, cleanedText, detectedAnalyst } = detectPasteIntent(text, false);
        if (!command) return;
        e.preventDefault();
        input.value = command + ' ' + cleanedText;
        const label = detectedAnalyst ? detectedAnalyst.charAt(0).toUpperCase() + detectedAnalyst.slice(1) + ' detected' : 'pattern detected';
        showPasteHint('ÃƒÂ¢Ã¢â‚¬Â Ã‚Â³ routing to ' + command + ' (' + label + ')');
      });
    });

    let dragDepth = 0;
    const dragOverlay = document.getElementById("drag-overlay");
    document.addEventListener("dragenter", (e) => {
      if (Array.from(e.dataTransfer?.items || []).some(i => i.kind === "file" && i.type.startsWith("image/"))) {
        dragDepth++;
        dragOverlay.classList.add("show");
      }
    });
    document.addEventListener("dragleave", () => {
      dragDepth--;
      if (dragDepth <= 0) { dragDepth = 0; dragOverlay.classList.remove("show"); }
    });
    document.addEventListener("dragover", (e) => e.preventDefault());
    document.addEventListener("drop", (e) => {
      e.preventDefault();
      dragDepth = 0;
      dragOverlay.classList.remove("show");
      const file = e.dataTransfer?.files[0];
      if (file && file.type.startsWith("image/")) handleImageBlob(file, file.type);
    });

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ CHAT ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    async function look(question) {
      showThinking("LOOKING...");
      sendBtn.disabled = true;
      try {
        const r = await fetch(BASE + "/see", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ question: question || "What's on this screen? Be brief." }) });
        const d = await r.json();
        hideThinking();
        addMessage("assistant", d.reply, "vision");
      } catch {
        hideThinking();
        addMessage("assistant", "Vision error.");
      }
      sendBtn.disabled = false;
      input.focus();
    }

    async function doAction(text) {
      showThinking("DOING...");
      sendBtn.disabled = true;
      const parts = text.split(" ");
      try {
        const r = await fetch(BASE + "/do", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ action: parts[0].toLowerCase(), value: parts.slice(1).join(" ") }) });
        const d = await r.json();
        hideThinking();
        addMessage("assistant", d.reply || "Done.", "vision");
      } catch {
        hideThinking();
        addMessage("assistant", "Action error.");
      }
      sendBtn.disabled = false;
      input.focus();
    }

    async function chat(text) {
      showThinking("THINKING...");
      sendBtn.disabled = true;
      try {
        const r = await fetch(BASE + "/chat", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ message: text, history }) });
        const d = await r.json();
        hideThinking();
        addMessage("assistant", d.reply);
        if (d.state) updateStateIndicator(d.state);
        history = d.history;
      } catch {
        hideThinking();
        addMessage("assistant", "Connection error.");
      }
      sendBtn.disabled = false;
      input.focus();
    }

    async function send() {
      try {
        let text = input.value.trim();
        if (!text) return;
        input.value = "";
        const ph = document.getElementById("paste-hint");
        if (ph) ph.style.display = "none";
        if (!text.startsWith('/')) {
          try {
            const det = detectPasteIntent(text, false);
            if (det && det.command) {
              if (typeof showPasteHint === 'function') {
                const label = det.detectedAnalyst
                  ? det.detectedAnalyst.charAt(0).toUpperCase() + det.detectedAnalyst.slice(1) + ' detected'
                  : 'pattern detected';
                showPasteHint('ÃƒÂ¢Ã¢â‚¬Â Ã‚Â³ routing to ' + det.command + ' (' + label + ')');
              }
              text = det.command + ' ' + det.cleanedText;
            }
          } catch (e) {
            console.error('[send] paste detect threw:', e);
          }
        }
        if (/^panic$/i.test(text)) {
          document.getElementById("panic-modal").classList.add("show");
          return;
        }
        const overrideMatch = text.match(/^override:\s*(.+)/i);
        if (overrideMatch) {
          logIntervention(overrideMatch[1]);
          return;
        }
        if (typeof checkMC === 'function') checkMC(text);
        addMessage("user", text);
        if (/^do /i.test(text)) return doAction(text.slice(3));
        if (/^look($| )/i.test(text)) return look(text.slice(4).trim());
        return chat(text);
      } catch (outerErr) {
        console.error('[send] fatal:', outerErr);
        addMessage('system', 'Send error: ' + (outerErr.message || outerErr));
      }
    }

    sendBtn.addEventListener("click", send);
    input.addEventListener("keydown", e => { if (e.key === "Enter") send(); });

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ CONNECTION ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    const connChip = document.getElementById("chip-conn");
    async function checkConn() {
      try {
        await fetch(BASE + "/health");
        connChip.className = "chip ok";
        document.getElementById("tb-dot").className = "";
        document.getElementById("actions").style.opacity = "";
        document.getElementById("actions").style.pointerEvents = "";
      } catch {
        connChip.className = "chip err";
        document.getElementById("tb-dot").className = "err";
        document.getElementById("actions").style.opacity = "0.3";
        document.getElementById("actions").style.pointerEvents = "none";
        toast("Server connection lost.");
      }
    }
    checkConn();
    setInterval(checkConn, 10000);

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ BOOT CHECK ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    (async () => {
      try {
        const r = await fetch(BASE + "/luke/boot-check");
        const d = await r.json();
        if (d.overall === "red") {
          const ul = document.getElementById("boot-check-list");
          ul.innerHTML = d.checks.map(c =>
            `<li class="${c.status}">${c.status === "green" ? "ÃƒÂ¢Ã…â€œÃ¢â‚¬Å“" : c.status === "yellow" ? "ÃƒÂ¢Ã…Â¡Ã‚Â " : "ÃƒÂ¢Ã…â€œÃ¢â‚¬â€"} ${c.name}: ${c.detail}</li>`
          ).join("");
          document.getElementById("boot-modal").classList.add("show");
        }
      } catch {}
    })();

    document.getElementById("boot-modal-close").addEventListener("click", () => {
      document.getElementById("boot-modal").classList.remove("show");
    });

    document.getElementById("panic-confirm").addEventListener("click", async () => {
      document.getElementById("panic-modal").classList.remove("show");
      try {
        await fetch(BASE + "/panic", { method: "POST" });
        addMessage("assistant", "PANIC executed ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â 02B killed, intraday stopped.", "alert");
      } catch { addMessage("assistant", "PANIC endpoint failed.", "alert"); }
    });
    document.getElementById("panic-cancel").addEventListener("click", () => {
      document.getElementById("panic-modal").classList.remove("show");
    });

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ METRICS PANEL ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    let metricsTextSummary = "";

    function openMetricsPanel() {
      document.getElementById("metrics-panel").classList.add("visible");
      loadMetrics();
    }
    function closeMetricsPanel() {
      document.getElementById("metrics-panel").classList.remove("visible");
    }

    document.getElementById("mp-close").addEventListener("click", closeMetricsPanel);
    document.getElementById("mp-load-btn").addEventListener("click", loadMetrics);

    document.getElementById("mp-copy-btn").addEventListener("click", () => {
      if (!metricsTextSummary) { toast("No metrics loaded yet."); return; }
      navigator.clipboard.writeText(metricsTextSummary)
        .then(() => toast("Summary copied to clipboard."))
        .catch(() => {
          const ta = document.createElement("textarea");
          ta.value = metricsTextSummary;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          ta.remove();
          toast("Summary copied.");
        });
    });

    async function loadMetrics() {
      const loadBtn  = document.getElementById("mp-load-btn");
      const statusEl = document.getElementById("mp-status");
      const content  = document.getElementById("mp-content");
      const hours    = parseInt(document.getElementById("mp-hours-input").value) || 24;
      loadBtn.disabled = true;
      statusEl.textContent = "loading...";
      try {
        const r = await fetch(BASE + "/agent/autonomous/metrics?hours=" + hours);
        const m = await r.json();
        if (m.error) { statusEl.textContent = "error: " + m.error; loadBtn.disabled = false; return; }
        metricsTextSummary = m.text_summary || "";
        statusEl.textContent = "since " + (m.since || "").slice(0, 16).replace("T", " ") + " UTC";
        content.innerHTML = renderMetrics(m);
      } catch { statusEl.textContent = "fetch failed"; }
      loadBtn.disabled = false;
    }

    function renderMetrics(m) {
      function row(key, val, cls) {
        return `<div class="mp-row"><span class="mp-key">${key}</span><span class="mp-val${cls ? " " + cls : ""}">${val}</span></div>`;
      }
      function section(label, rows) {
        return `<div class="mp-section"><div class="mp-section-label">${label}</div>${rows.join("")}</div>`;
      }
      const pnlCls = m.paper_pnl_total > 0 ? "pos" : m.paper_pnl_total < 0 ? "neg" : "";
      const avgCls = m.paper_pnl_avg_per_trade > 0 ? "pos" : m.paper_pnl_avg_per_trade < 0 ? "neg" : "";
      const rejectTotal = Object.values(m.rejects_by_reason || {}).reduce((a, b) => a + b, 0);
      const rejectStr = rejectTotal === 0 ? "0" :
        rejectTotal + " ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â " + Object.entries(m.rejects_by_reason)
          .sort((a, b) => b[1] - a[1])
          .map(([k, v]) => k.replace(/_/g, " ") + "ÃƒÆ’Ã¢â‚¬â€" + v)
          .join(", ");
      const signalsHtml = section("SIGNALS", [
        row("evaluated", m.signals_evaluated),
        row("staged", m.signals_staged),
        row("gate rejections", rejectStr, rejectTotal > 0 ? "warn" : ""),
      ]);
      const tradesHtml = section("TRADES", [
        row("opened", m.paper_trades_opened),
        row("closed", m.paper_trades_closed),
        row("total P&L", "$" + m.paper_pnl_total, pnlCls),
        row("avg/trade", "$" + m.paper_pnl_avg_per_trade, avgCls),
        m.avg_time_to_protection_confirmed_ms !== null
          ? row("entryÃƒÂ¢Ã¢â‚¬Â Ã¢â‚¬â„¢protected", (m.avg_time_to_protection_confirmed_ms / 1000).toFixed(1) + "s")
          : row("entryÃƒÂ¢Ã¢â‚¬Â Ã¢â‚¬â„¢protected", "N/A (no live execs)"),
      ]);
      const systemHtml = section("SYSTEM", [
        row("reconcile mismatches", m.reconciliation_mismatches_count, m.reconciliation_mismatches_count > 0 ? "warn" : ""),
        row("scheduler jobs failed", m.scheduler_jobs_failed_count, m.scheduler_jobs_failed_count > 0 ? "warn" : ""),
        row("critical events", m.critical_events.length, m.critical_events.length > 0 ? "neg" : ""),
      ]);
      let criticalHtml = "";
      if (m.critical_events && m.critical_events.length > 0) {
        const items = m.critical_events.map(e =>
          `<div class="mp-critical-item"><span class="mp-critical-ts">${(e.timestamp || "").slice(11, 16)}</span>${e.type} ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â ${e.summary || ""}</div>`
        ).join("");
        criticalHtml = `<div class="mp-section"><div class="mp-section-label">CRITICAL LOG</div>${items}</div>`;
      }
      return signalsHtml + tradesHtml + systemHtml + criticalHtml;
    }

    // ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ LUKE PANEL ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬    let lukePollInterval = null;

    function openLukePanel() {
      document.getElementById("luke-panel").classList.add("visible");
    }
    function closeLukePanel() {
      document.getElementById("luke-panel").classList.remove("visible");
      clearInterval(lukePollInterval);
      lukePollInterval = null;
    }

    document.getElementById("lp-close").addEventListener("click", closeLukePanel);

    // Ã¢â‚¬â€Ã¢â‚¬â€ STATUS PANEL AUTO-REFRESH ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬

    function parseStatusReply(text) {
      const spEl = (id, val, cls) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.textContent = val;
        el.className = "sp-item" + (cls ? " " + cls : "");
      };

      const levelsMatch = text.match(/Levels:\s*(ÃƒÂ¢Ã…â€œÃ¢â‚¬Â¦[^\n]*|ÃƒÂ¢Ã‚ÂÃ…â€™[^\n]*)/i);
      if (levelsMatch) {
        const ok = levelsMatch[1].startsWith("ÃƒÂ¢Ã…â€œÃ¢â‚¬Â¦");
        spEl("sp-levels", "LEVELS: " + (ok ? "YES" : "NO"), ok ? "ok" : "err");
      }

      const zoneMatch = text.match(/Zone:\s*([^\n|]+)/i) || text.match(/ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã‚Â\s*([\d.]+)\s+(\S+)\s+(\S+)/);
      if (zoneMatch) {
        spEl("sp-confluence", "ZONE: " + (zoneMatch[1] || "").trim().slice(0, 30), "info");
      } else if (/no HIGH confluence/i.test(text)) {
        spEl("sp-confluence", "ZONE: none", "warn");
      }

      const tradeMatch = text.match(/(\d+)\s+trades\s*\|\s*(\d+)W\s+(\d+)L\s*\|\s*Net:\s*([+\-][\d.]+)/i);
      if (tradeMatch) {
        const net = parseFloat(tradeMatch[4]);
        spEl("sp-trades", `TODAY: ${tradeMatch[1]}t ${tradeMatch[2]}W/${tradeMatch[3]}L ${tradeMatch[4]}pts`, net >= 0 ? "ok" : "err");
        const tbTrades = document.getElementById("tb-trades-val");
        if (tbTrades) tbTrades.textContent = `${tradeMatch[1]} trades ${tradeMatch[2]}W ${tradeMatch[3]}L`;
      } else if (/No trades logged/i.test(text)) {
        spEl("sp-trades", "TODAY: 0 trades", "");
        const tbTrades = document.getElementById("tb-trades-val");
        if (tbTrades) tbTrades.textContent = "0 trades 0W 0L";
      }

      const stateMatch = text.match(/Emotional state:\s*([^\n]+)/i);
      if (stateMatch) {
        const s = stateMatch[1];
        const cls = /ÃƒÂ¢Ã‚ÂÃ…â€™/.test(s) ? "err" : /ÃƒÂ¢Ã…Â¡Ã‚Â /.test(s) ? "warn" : "ok";
        spEl("sp-state", "STATE: " + (cls === "ok" ? "ÃƒÂ°Ã…Â¸Ã…Â¸Ã‚Â¢" : cls === "warn" ? "ÃƒÂ°Ã…Â¸Ã…Â¸Ã‚Â¡" : "ÃƒÂ°Ã…Â¸Ã¢â‚¬ÂÃ‚Â´"), cls);
      }

      spEl("sp-meds", "IN MEMORY OF LUKE", "");

      const regimeMatch = text.match(/[Rr]egime[:\s]+([A-Z_]+)/);
      if (regimeMatch) {
        const regEl = document.getElementById("tb-regime-val");
        if (regEl) {
          const r = regimeMatch[1].toUpperCase();
          regEl.textContent = r;
          regEl.className = r === "RISK_ON" ? "risk-on" : r === "RISK_OFF" ? "risk-off" : "";
        }
      }
    }

    async function refreshStatusPanel() {
      try {
        const r = await fetch("/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ message: "/status" })
        });
        const d = await r.json();
        if (d.reply) parseStatusReply(d.reply);
      } catch {}
    }

    refreshStatusPanel();
    setInterval(refreshStatusPanel, 60000);
  </script>
</body>
</html>