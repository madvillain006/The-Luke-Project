        private string TimeBucket(DateTime timestamp)
        {
            int minutes = timestamp.Hour * 60 + timestamp.Minute;
            if (minutes < 9 * 60 + 30)
                return "overnight_premarket";
            if (minutes < 11 * 60)
                return "rth_open";
            if (minutes < 14 * 60)
                return "midday";
            if (minutes < 15 * 60)
                return "afternoon";
            if (minutes < 16 * 60)
                return "power_hour";
            return "post_rth";
        }

        private double TimeBonus(string bucket)
        {
            if (bucket == "rth_open")
                return 0.6;
            if (bucket == "power_hour")
                return 1.0;
            if (bucket == "afternoon")
                return 0.4;
            if (bucket == "overnight_premarket")
                return 0.35;
            if (bucket == "midday")
                return 0.15;
            return 0.0;
        }

        private void EnsureTelemetryHeader()
        {
            if (telemetryHeaderChecked || string.IsNullOrWhiteSpace(TelemetryCsvPath))
                return;
            telemetryHeaderChecked = true;
            string dir = Path.GetDirectoryName(TelemetryCsvPath);
            if (!string.IsNullOrWhiteSpace(dir))
                Directory.CreateDirectory(dir);
            if (File.Exists(TelemetryCsvPath) && new FileInfo(TelemetryCsvPath).Length > 0)
                return;
            File.AppendAllText(TelemetryCsvPath,
                "event_type,run_id,instrument,bar_period_minutes,session_date,rule,fill_mode,setup_level,swept_low,trap_detected_timestamp_et,reclaim_detected_timestamp_et,classification_complete_timestamp_et,candidate_fired_timestamp_et,candidate_score,non_acceptance_score,target_points,stop_policy,entry_timestamp_et,entry_price,first_hit_event,first_hit_timestamp_et,first_hit_points,target_first,stop_first,same_bar_stop_and_target,notes" + Environment.NewLine);
        }

        private void WriteTelemetry(string eventType, Feature feature, ActiveSimulation simulation, string notes)
        {
            if (string.IsNullOrWhiteSpace(TelemetryCsvPath))
                return;
            try
            {
                EnsureTelemetryHeader();
                string instrument = Instrument == null ? string.Empty : Instrument.FullName;
                string sessionDate = feature == null ? activeSessionDate : feature.SessionDate;
                string line = string.Join(",", new[]
                {
                    Csv(eventType),
                    Csv(actualRunId),
                    Csv(instrument),
                    Csv(PrimaryBarsPeriodTelemetry()),
                    Csv(sessionDate),
                    Csv(PrimaryRule),
                    Csv(PrimaryFillMode),
                    Csv(feature == null ? "" : Format(feature.SetupLevel)),
                    Csv(feature == null ? "" : Format(feature.SweptLow)),
                    Csv(feature == null ? "" : FormatDate(feature.TrapTime)),
                    Csv(feature == null ? "" : FormatDate(feature.ReclaimTime)),
                    Csv(feature == null ? "" : FormatDate(feature.ClassificationCompleteTime)),
                    Csv(feature == null ? "" : FormatDate(feature.CandidateFiredTime)),
                    Csv(feature == null ? "" : Format(feature.CandidateScore)),
                    Csv(feature == null ? "" : Format(feature.NonAcceptanceScore)),
                    Csv(Format(Tp1Points)),
                    Csv(PrimaryStopPolicy),
                    Csv(simulation == null ? (feature == null ? "" : FormatDate(feature.EntryTimestamp)) : FormatDate(simulation.EntryTime)),
                    Csv(simulation == null ? (feature == null ? "" : Format(feature.EntryPrice)) : Format(simulation.EntryPrice)),
                    Csv(simulation == null ? "" : simulation.FirstHitEvent),
                    Csv(simulation == null ? "" : FormatDate(simulation.FirstHitTimestamp)),
                    Csv(simulation == null ? "" : Format(simulation.FirstHitPoints)),
                    Csv(simulation != null && simulation.TargetFirst ? "true" : "false"),
                    Csv(simulation != null && simulation.StopFirst ? "true" : "false"),
                    Csv(simulation != null && simulation.SameBarStopAndTarget ? "true" : "false"),
                    Csv(notes ?? string.Empty),
                });
                File.AppendAllText(TelemetryCsvPath, line + Environment.NewLine);
            }
            catch (Exception ex)
            {
                Print("ManciniFbdStrategyAnalyzer telemetry error: " + ex.Message);
            }
        }

        private static string Csv(string value)
        {
            string text = value ?? string.Empty;
            if (text.IndexOfAny(new[] { ',', '"', '\r', '\n' }) < 0)
                return text;
            return "\"" + text.Replace("\"", "\"\"") + "\"";
        }

        private static string FormatDate(DateTime value)
        {
            return value == DateTime.MinValue ? string.Empty : value.ToString("yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture);
        }

        private static string Format(double value)
        {
            if (double.IsNaN(value) || double.IsInfinity(value))
                return string.Empty;
            return value.ToString("0.####", CultureInfo.InvariantCulture);
        }

        private static double WeightedAverage(double currentAverage, int currentQuantity, double newPrice, int newQuantity)
        {
            if (currentQuantity <= 0)
                return newPrice;
            int totalQuantity = currentQuantity + newQuantity;
            if (totalQuantity <= 0)
                return newPrice;
            return (currentAverage * currentQuantity + newPrice * newQuantity) / totalQuantity;
        }

        private static bool ContainsAny(string text, params string[] needles)
        {
            for (int i = 0; i < needles.Length; i++)
            {
                if (text.IndexOf(needles[i], StringComparison.OrdinalIgnoreCase) >= 0)
                    return true;
            }
            return false;
        }

        private static double Indicator(bool value)
        {
            return value ? 1.0 : 0.0;
        }

        private static double Clamp(double value, double low, double high)
        {
            if (double.IsNaN(value))
                return low;
            return Math.Max(low, Math.Min(high, value));
        }

        private static DateTime MaxDate(DateTime left, DateTime right)
        {
            if (left == DateTime.MinValue)
                return right;
            if (right == DateTime.MinValue)
                return left;
            return left > right ? left : right;
        }

        private static double RoundToTick(double price)
        {
            return Math.Round(price / Tick, MidpointRounding.AwayFromZero) * Tick;
        }

        private static double ParseDouble(string value)
        {
            double parsed;
            return double.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out parsed) ? parsed : double.NaN;
        }

        private static bool ParseBool(string value)
        {
            string text = (value ?? string.Empty).Trim();
            return text.Equals("true", StringComparison.OrdinalIgnoreCase)
                || text.Equals("1", StringComparison.OrdinalIgnoreCase)
                || text.Equals("yes", StringComparison.OrdinalIgnoreCase);
        }

        private static int StringCompareDate(string left, string right)
        {
            return string.Compare(left ?? string.Empty, right ?? string.Empty, StringComparison.Ordinal);
        }

        private static string Get(Dictionary<string, string> row, string key)
        {
            string value;
            return row.TryGetValue(key, out value) ? value : string.Empty;
        }

        private static Dictionary<string, string> BuildCsvRow(List<string> header, List<string> values)
        {
            Dictionary<string, string> row = new Dictionary<string, string>(StringComparer.Ordinal);
            for (int i = 0; i < header.Count; i++)
                row[header[i]] = i < values.Count ? values[i] : string.Empty;
            return row;
        }

        private static List<string> SplitCsvLine(string line)
        {
            List<string> values = new List<string>();
            StringBuilder current = new StringBuilder();
            bool inQuotes = false;
            for (int i = 0; i < line.Length; i++)
            {
                char ch = line[i];
                if (ch == '"')
                {
                    if (inQuotes && i + 1 < line.Length && line[i + 1] == '"')
                    {
                        current.Append('"');
                        i++;
                    }
                    else
                    {
                        inQuotes = !inQuotes;
                    }
                }
                else if (ch == ',' && !inQuotes)
                {
                    values.Add(current.ToString());
                    current.Length = 0;
                }
                else
                {
                    current.Append(ch);
                }
            }
            values.Add(current.ToString());
            return values;
        }

