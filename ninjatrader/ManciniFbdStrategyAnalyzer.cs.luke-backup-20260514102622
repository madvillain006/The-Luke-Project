        private void LoadManciniLevels()
        {
            levelsByPlanDate.Clear();
            allManciniLevels.Clear();
            if (string.IsNullOrWhiteSpace(EventsCsvPath) || !File.Exists(EventsCsvPath))
            {
                WriteTelemetry("LEVEL_LOAD_ERROR", null, null, "missing_events_csv=" + EventsCsvPath);
                return;
            }

            string[] lines = File.ReadAllLines(EventsCsvPath);
            if (lines.Length < 2)
                return;
            List<string> header = SplitCsvLine(lines[0]);
            Dictionary<string, Dictionary<double, ManciniLevel>> grouped = new Dictionary<string, Dictionary<double, ManciniLevel>>(StringComparer.Ordinal);
            for (int i = 1; i < lines.Length; i++)
            {
                if (string.IsNullOrWhiteSpace(lines[i]))
                    continue;
                Dictionary<string, string> row = BuildCsvRow(header, SplitCsvLine(lines[i]));
                string direction = Get(row, "direction").Trim().ToLowerInvariant();
                bool longEligible = ParseBool(Get(row, "long_eligible"));
                string planDate = Get(row, "plan_date").Trim();
                double price = ParseDouble(Get(row, "price"));
                if (double.IsNaN(price))
                    price = ParseDouble(Get(row, "zone_low"));
                if (double.IsNaN(price))
                    price = ParseDouble(Get(row, "zone_high"));
                if (string.IsNullOrWhiteSpace(planDate) || direction != "support" || !longEligible || double.IsNaN(price))
                    continue;

                ManciniLevel level = new ManciniLevel
                {
                    PlanDate = planDate,
                    PubDate = string.IsNullOrWhiteSpace(Get(row, "pub_date")) ? planDate : Get(row, "pub_date").Trim(),
                    Price = RoundToTick(price),
                    Direction = direction,
                    PrimaryRole = Get(row, "primary_role"),
                    SourceKind = Get(row, "source_kind"),
                    SourcePath = Get(row, "source_path"),
                    SourceId = Get(row, "source_id"),
                    SourceSnippet = Get(row, "source_snippet"),
                    Tags = Get(row, "tags"),
                    OcrVerified = ParseBool(Get(row, "ocr_verified")),
                };
                level.SourceConfidence = ComputeSourceConfidence(level);
                level.MajorSourceBonus = ComputeMajorSourceBonus(level);
                allManciniLevels.Add(level);

                Dictionary<double, ManciniLevel> byPrice;
                if (!grouped.TryGetValue(planDate, out byPrice))
                {
                    byPrice = new Dictionary<double, ManciniLevel>();
                    grouped[planDate] = byPrice;
                }
                ManciniLevel existing;
                if (!byPrice.TryGetValue(level.Price, out existing) || level.SourceConfidence > existing.SourceConfidence)
                    byPrice[level.Price] = level;
            }

            foreach (KeyValuePair<string, Dictionary<double, ManciniLevel>> item in grouped)
            {
                List<ManciniLevel> levels = new List<ManciniLevel>(item.Value.Values);
                levels.Sort(delegate(ManciniLevel left, ManciniLevel right) { return left.Price.CompareTo(right.Price); });
                levelsByPlanDate[item.Key] = levels;
            }
            WriteTelemetry("LEVELS_LOADED", null, null, "plan_dates=" + levelsByPlanDate.Count.ToString(CultureInfo.InvariantCulture)
                + " baked_levels=" + allManciniLevels.Count.ToString(CultureInfo.InvariantCulture));
        }

        private double ComputeSourceConfidence(ManciniLevel level)
        {
            string text = (level.SourceKind + " " + level.SourcePath + " " + level.SourceSnippet + " " + level.Tags + " " + level.PrimaryRole).ToLowerInvariant();
            double score = 0.45;
            if (level.OcrVerified)
                score += 0.10;
            if (ContainsAny(text, "mancini", "daily", "plan", "support"))
                score += 0.10;
            if (ContainsAny(text, "major", "key", "must hold", "line in sand", "supports", "big"))
                score += 0.10;
            if (ContainsAny(text, "negative", "sr_list_only", "data_only"))
                score -= 0.20;
            return Math.Round(Clamp(score, 0.0, 0.85), 4);
        }

        private double ComputeMajorSourceBonus(ManciniLevel level)
        {
            string text = (level.SourceSnippet + " " + level.PrimaryRole + " " + level.Tags).ToLowerInvariant();
            return Indicator(ContainsAny(text, "major", "massive", "significant", "daily low", "shelf", "low held", "big shelf", "must hold"));
        }

        private ReclaimMetrics ComputeReclaimMetrics(double level, int reclaimIndex)
        {
            ReclaimMetrics result = new ReclaimMetrics();
            if (reclaimIndex < 0 || reclaimIndex > CurrentBar)
                return result;

            double range = Math.Max(BarHigh(reclaimIndex) - BarLow(reclaimIndex), Tick);
            result.ReclaimCloseLocation = (CloseAt(reclaimIndex) - BarLow(reclaimIndex)) / range;
            result.ReclaimRange = BarHigh(reclaimIndex) - BarLow(reclaimIndex);

            int end = Math.Min(CurrentBar, reclaimIndex + 15);
            int tenMinuteEnd = Math.Min(CurrentBar, reclaimIndex + 10);
            int acceptanceCloses = 0;
            DateTime acceptanceScoreTime = DateTime.MinValue;
            DateTime acceptanceClassificationTime = DateTime.MinValue;
            for (int index = reclaimIndex; index <= end; index++)
            {
                if (CloseAt(index) >= level)
                {
                    acceptanceCloses++;
                    if (acceptanceCloses <= 3)
                    {
                        result.AcceptanceClosesUsedForScore = acceptanceCloses;
                        acceptanceScoreTime = BarTime(index);
                    }
                    if (acceptanceCloses >= 3 && acceptanceClassificationTime == DateTime.MinValue)
                        acceptanceClassificationTime = BarTime(index);
                }
                else
                {
                    break;
                }
            }

            double threshold = level + NonAcceptancePoints;
            bool thresholdStarted = false;
            for (int index = reclaimIndex; index <= end; index++)
            {
                if (CloseAt(index) >= threshold)
                {
                    thresholdStarted = true;
                    if (result.FirstThresholdCloseTime == DateTime.MinValue)
                        result.FirstThresholdCloseTime = BarTime(index);
                    result.NonAcceptanceCloses++;
                    if (result.NonAcceptanceCloses <= 3)
                    {
                        result.NonAcceptanceClosesUsedForScore = result.NonAcceptanceCloses;
                        result.NonAcceptanceScoreTime = BarTime(index);
                    }
                    double scoreAvailable = 0.40 + 0.30 * Clamp(result.NonAcceptanceCloses / 3.0, 0, 1);
                    if (scoreAvailable >= MinimumNonAcceptanceScore && result.NonAcceptanceClassificationTime == DateTime.MinValue)
                        result.NonAcceptanceClassificationTime = BarTime(index);
                }
                else if (thresholdStarted && BarLow(index) <= level + 0.5)
                {
                    result.FirstRetestHolds = CloseAt(index) >= level;
                    if (result.FirstRetestHolds)
                        result.NonAcceptanceScoreTime = BarTime(index);
                    if (result.FirstRetestHolds && result.NonAcceptanceClassificationTime == DateTime.MinValue)
                        result.NonAcceptanceClassificationTime = BarTime(index);
                    break;
                }
                else if (thresholdStarted)
                {
                    break;
                }
            }

            for (int index = reclaimIndex; index <= tenMinuteEnd; index++)
            {
                if (CloseAt(index) >= threshold)
                {
                    result.AnyCloseAboveThresholdWithinTenMinutes = true;
                    break;
                }
            }

            DateTime latestScoreTime = MaxDate(acceptanceClassificationTime, result.NonAcceptanceClassificationTime);
            if (latestScoreTime == DateTime.MinValue)
                latestScoreTime = BarTime(Math.Min(end, CurrentBar));
            result.NoCloseBackBelowBeforeEntry = true;
            for (int index = reclaimIndex; index <= CurrentBar; index++)
            {
                if (BarTime(index) > latestScoreTime)
                    break;
                if (CloseAt(index) < level)
                {
                    result.NoCloseBackBelowBeforeEntry = false;
                    break;
                }
            }
            result.AcceptanceScoreTime = acceptanceScoreTime;
            return result;
        }

        private PriorStats ComputePriorTouchStats(double level, int trapIndex)
        {
            PriorStats stats = new PriorStats();
            int firstTouch = -1;
            int lastTouch = -1;
            for (int index = sessionStartBar; index < trapIndex; index++)
            {
                if (BarLow(index) <= level + 1.0 && BarHigh(index) >= level - 1.0)
                {
                    stats.PriorTouchCount++;
                    if (firstTouch < 0)
                        firstTouch = index;
                    lastTouch = index;
                }
            }
            if (firstTouch < 0 || lastTouch < 0)
                return stats;
            stats.PriorHoldMinutes = Math.Max((BarTime(lastTouch) - BarTime(firstTouch)).TotalMinutes, 0.0);
            double highest = level;
            for (int index = firstTouch; index < trapIndex; index++)
                highest = Math.Max(highest, BarHigh(index));
            stats.PriorBouncePoints = Math.Max(highest - level, 0.0);
            return stats;
        }

        private string AcceptanceFamily(bool firstReclaimFailed, int multiLevelFlushCount, double flushDepth, int acceptanceCloses, double nonAcceptanceScore)
        {
            if (nonAcceptanceScore >= MinimumNonAcceptanceScore)
                return "non_acceptance_protocol";
            if (firstReclaimFailed && acceptanceCloses >= 2)
                return "classic_acceptance_second_attempt_reclaim";
            if (multiLevelFlushCount >= 2 && flushDepth >= 4.0)
                return "ladder_first_reclaim";
            if (acceptanceCloses >= 3)
                return "classic_acceptance_backtest_from_below";
            return "simple_reclaim_unclassified";
        }

        private ManciniLevel NextLevelAbove(double entryPrice)
        {
            ManciniLevel chosen = null;
            for (int i = 0; i < activeLevels.Count; i++)
            {
                ManciniLevel level = activeLevels[i];
                if (level.Price <= entryPrice + Tick)
                    continue;
                if (RespectLevelPublicationDate && StringCompareDate(level.PubDate, activeSessionDate) > 0)
                    continue;
                if (chosen == null || level.Price < chosen.Price)
                    chosen = level;
            }
            return chosen;
        }

        private int CountLevelsBetween(double low, double high)
        {
            double lower = Math.Min(low, high);
            double upper = Math.Max(low, high);
            int count = 0;
            for (int i = 0; i < activeLevels.Count; i++)
            {
                double price = activeLevels[i].Price;
                if (price > lower && price < upper)
                    count++;
            }
            return count;
        }

