        protected override void OnBarUpdate()
        {
            if (CurrentBar < BarsRequiredToTrade)
                return;

            if (RequireOneMinuteBars && !IsOneMinutePrimary())
            {
                if (!warnedBadTimeframe)
                {
                    warnedBadTimeframe = true;
                    WriteTelemetry("REJECT", null, null, "requires_1m_bars_for_primary_build_path primary_bars_period=" + PrimaryBarsPeriodDebug());
                }
                return;
            }

            if (State == State.Realtime && !AllowRealtimePlaybackSim)
            {
                if (!warnedRealtimeDisabled)
                {
                    warnedRealtimeDisabled = true;
                    WriteTelemetry("REJECT", null, null, "realtime_disabled_allow_realtime_playback_sim_false");
                }
                return;
            }

            if (State == State.Realtime && AllowRealtimePlaybackSim && !IsPermittedRealtimeAccount())
            {
                if (!warnedRealtimeAccountRejected)
                {
                    warnedRealtimeAccountRejected = true;
                    WriteTelemetry("REJECT", null, null, "realtime_account_not_permitted account_policy=sim_playback_or_exact_permitted_realtime_accounts");
                }
                return;
            }

            string sessionDate = ChartSessionDate(Time[0]);
            if (!string.Equals(sessionDate, activeSessionDate, StringComparison.Ordinal))
                ResetSession(sessionDate);

            ProcessPendingSignals();
            ProcessActiveSimulations();
            ProcessManagedTimeoutExits();
            CancelExpiredAnalyzerEntryOrders();

            if (activeLevels.Count == 0)
            {
                if (!warnedNoLevels)
                {
                    warnedNoLevels = true;
                    WriteTelemetry("NO_LEVELS", null, null, "no_source_eligible_mancini_levels_for_session=" + sessionDate);
                }
                return;
            }

            for (int i = 0; i < activeLevels.Count; i++)
                UpdateLevel(activeLevels[i], levelStates[activeLevels[i].Price]);
        }

        protected override void OnExecutionUpdate(Execution execution, string executionId, double price, int quantity, MarketPosition marketPosition, string orderId, DateTime time)
        {
            if (execution == null || execution.Order == null)
                return;

            TrackManagedExecution(execution, price, quantity, time);

            string fromEntrySignal = execution.Order.FromEntrySignal ?? string.Empty;
            string signalName;
            if (!t1EntryToSignal.TryGetValue(fromEntrySignal, out signalName))
                return;

            RunnerOrderState state;
            if (!runnerOrderStates.TryGetValue(signalName, out state) || state.RunnerQuantity <= 0 || state.RunnerStopMovedToBreakeven)
                return;

            if (execution.Order.OrderAction != OrderAction.Sell)
                return;
            if (price < state.Tp1Price - Tick)
                return;

            SetStopLoss(state.EntryNameT2, CalculationMode.Price, state.EntryPrice, false);
            state.RunnerStopMovedToBreakeven = true;
            WriteTelemetry("RUNNER_STOP_BREAKEVEN", state.Feature, null, "signal=" + signalName + " entry=" + Format(state.EntryPrice) + " tp1=" + Format(state.Tp1Price));
        }

        protected override void OnOrderUpdate(Order order, double limitPrice, double stopPrice, int quantity, int filled, double averageFillPrice, OrderState orderState, DateTime time, ErrorCode error, string nativeError)
        {
            if (order == null)
                return;

            string orderName = order.Name ?? string.Empty;
            AnalyzerEntryOrderState state;
            if (!analyzerEntryOrders.TryGetValue(orderName, out state))
                return;

            state.Order = order;
            if (orderState == OrderState.Filled)
            {
                analyzerEntryOrders.Remove(orderName);
                WriteTelemetry("ORDER_FILLED", state.Feature, null, "signal=" + state.SignalName + " order=" + orderName + " order_update_time=" + FormatDate(time) + " avg_fill=" + Format(averageFillPrice));
            }
            else if (orderState == OrderState.Cancelled || orderState == OrderState.Rejected)
            {
                analyzerEntryOrders.Remove(orderName);
                if (filled <= 0)
                    managedExecutionStates.Remove(orderName);
                WriteTelemetry(orderState == OrderState.Cancelled ? "ORDER_CANCELLED" : "ORDER_REJECTED", state.Feature, null,
                    "signal=" + state.SignalName + " order=" + orderName + " order_update_time=" + FormatDate(time) + " filled=" + filled.ToString(CultureInfo.InvariantCulture) + " error=" + error + " native_error=" + nativeError);
            }
        }

        private void ResetSession(string sessionDate)
        {
            CancelAllAnalyzerEntryOrders("session_reset_before_level_reload");
            activeSessionDate = sessionDate;
            sessionStartBar = CurrentBar;
            warnedNoLevels = false;
            levelStates.Clear();
            activeLevels.Clear();
            pendingSignals.Clear();
            activeSimulations.Clear();
            runnerOrderStates.Clear();
            t1EntryToSignal.Clear();
            analyzerEntryOrders.Clear();

            List<ManciniLevel> levels;
            bool hasExactPlanLevels = levelsByPlanDate.TryGetValue(sessionDate, out levels);
            string levelMode;
            if (UseBakedLevelUniverse)
                levels = BuildActiveLevelUniverse(sessionDate, Close[0], hasExactPlanLevels ? levels : null, out levelMode);
            else if (!hasExactPlanLevels)
            {
                WriteTelemetry("SESSION_READY", null, null, "session=" + sessionDate + " levels=0 level_mode=exact_plan_date_only");
                return;
            }
            else
            {
                levelMode = "exact_plan_date_only";
            }

            for (int i = 0; i < levels.Count; i++)
            {
                ManciniLevel level = levels[i];
                if (RespectLevelPublicationDate && StringCompareDate(level.PubDate, sessionDate) > 0)
                    continue;
                activeLevels.Add(level);
                levelStates[level.Price] = new LevelRuntimeState();
            }
            WriteTelemetry("SESSION_READY", null, null, "session=" + sessionDate
                + " levels=" + activeLevels.Count.ToString(CultureInfo.InvariantCulture)
                + " level_mode=" + levelMode
                + " exact_plan_levels=" + (hasExactPlanLevels ? "true" : "false")
                + " reference_price=" + Format(Close[0])
                + " window_points=" + Format(ActiveLevelWindowPoints)
                + " respect_pub_date=" + (RespectLevelPublicationDate ? "true" : "false"));
        }

        private List<ManciniLevel> BuildActiveLevelUniverse(string sessionDate, double referencePrice, List<ManciniLevel> exactPlanLevels, out string levelMode)
        {
            levelMode = "baked_level_universe";
            Dictionary<double, ManciniLevel> byPrice = new Dictionary<double, ManciniLevel>();
            AddLevelUniverseCandidates(byPrice, allManciniLevels, sessionDate, referencePrice, true);
            if (exactPlanLevels != null)
                AddLevelUniverseCandidates(byPrice, exactPlanLevels, sessionDate, referencePrice, false);

            List<ManciniLevel> levels = new List<ManciniLevel>(byPrice.Values);
            levels.Sort(delegate(ManciniLevel left, ManciniLevel right) { return left.Price.CompareTo(right.Price); });
            return levels;
        }

        private void AddLevelUniverseCandidates(Dictionary<double, ManciniLevel> byPrice, List<ManciniLevel> candidates, string sessionDate, double referencePrice, bool applyWindow)
        {
            if (candidates == null)
                return;

            double window = Math.Max(0.0, ActiveLevelWindowPoints);
            for (int i = 0; i < candidates.Count; i++)
            {
                ManciniLevel level = candidates[i];
                if (level.SourceConfidence < MinimumLevelSourceConfidence)
                    continue;
                if (RespectLevelPublicationDate && StringCompareDate(level.PubDate, sessionDate) > 0)
                    continue;
                if (applyWindow && window > 0.0 && Math.Abs(level.Price - referencePrice) > window)
                    continue;

                ManciniLevel existing;
                if (!byPrice.TryGetValue(level.Price, out existing) || level.SourceConfidence > existing.SourceConfidence)
                    byPrice[level.Price] = level;
            }
        }

        private void UpdateLevel(ManciniLevel level, LevelRuntimeState state)
        {
            if (state.Done)
                return;

            if (state.Phase == RuntimePhase.Watching)
            {
                if (CurrentBar - state.LastTrapBar < 20)
                    return;
                double previousClose = CurrentBar > 0 ? Close[1] : Open[0];
                if (previousClose >= level.Price - Tick && Low[0] <= level.Price - Tick)
                    CaptureTrap(level, state);
                return;
            }

            if (state.Phase == RuntimePhase.BreakdownDetected)
            {
                if (Low[0] < state.SweptLow)
                    state.SweptLow = Low[0];

                if (CurrentBar - state.TrapBarIndex > 90)
                {
                    ResetLevelState(state);
                    return;
                }

                if (Close[0] >= level.Price)
                {
                    state.PendingReclaimBarIndex = CurrentBar;
                    state.PendingReclaimTime = Time[0];
                    state.PendingReclaimClose = Close[0];
                    state.Phase = RuntimePhase.PendingReclaimConfirm;
                }
                return;
            }

            if (state.Phase == RuntimePhase.PendingReclaimConfirm)
            {
                if (Low[0] < state.SweptLow)
                    state.SweptLow = Low[0];

                if (CurrentBar == state.PendingReclaimBarIndex)
                    return;

                if (Close[0] < level.Price)
                {
                    state.FirstReclaimFailed = true;
                    state.PendingReclaimBarIndex = -1;
                    state.Phase = RuntimePhase.BreakdownDetected;
                    return;
                }

                state.ReclaimBarIndex = state.PendingReclaimBarIndex;
                state.ReclaimTime = state.PendingReclaimTime;
                state.FirstReclaimClose = state.PendingReclaimClose;
                state.Phase = RuntimePhase.ReclaimWatch;
                EvaluateCandidate(level, state);
                return;
            }

            if (state.Phase == RuntimePhase.ReclaimWatch)
            {
                if (Low[0] < state.SweptLow)
                    state.SweptLow = Low[0];
                EvaluateCandidate(level, state);
                if (!state.Done && CurrentBar - state.ReclaimBarIndex > 15)
                    ResetLevelState(state);
            }
        }

        private void CaptureTrap(ManciniLevel level, LevelRuntimeState state)
        {
            state.Phase = RuntimePhase.BreakdownDetected;
            state.TrapBarIndex = CurrentBar;
            state.LastTrapBar = CurrentBar;
            state.TrapTime = Time[0];
            state.SweptLow = Low[0];
            state.FirstReclaimFailed = false;
            state.PendingReclaimBarIndex = -1;
            state.ReclaimBarIndex = -1;
            state.Done = false;
            WriteTelemetry("TRAP", BuildFeature(level, state, false), null, "trap_detected");
        }

        private void EvaluateCandidate(ManciniLevel level, LevelRuntimeState state)
        {
            Feature feature = BuildFeature(level, state, true);
            if (feature == null)
                return;
            if (!RuleMatches(feature))
                return;

            state.Done = true;
            candidateCounter++;
            string signalName = "MFBD" + candidateCounter.ToString(CultureInfo.InvariantCulture);
            WriteTelemetry("SIGNAL", feature, null, "signal=" + signalName + " candidate_fired");
            pendingSignals.Add(new PendingSignal
            {
                Feature = feature,
                SignalName = signalName,
                SignalBarIndex = CurrentBar,
            });
        }

        private void SubmitAnalyzerOrders(string signalName, Feature feature)
        {
            int qty = Math.Max(1, AnalyzerQuantity);
            int qtyT1 = qty;
            int qtyT2 = 0;
            if (SplitTp1Tp2Runner && qty >= 2)
            {
                qtyT1 = Math.Max(1, qty / 2);
                qtyT2 = qty - qtyT1;
            }

            double entry = PlannedEntryPrice(feature);
            double stop = PlannedStopPrice(feature);
            double tp1 = PlannedTp1Price(entry);
            double tp2 = PlannedTp2Price(feature, entry, tp1);
            string t1Name = signalName + "T1";
            string t2Name = signalName + "T2";

            SetStopLoss(t1Name, CalculationMode.Price, stop, false);
            SetProfitTarget(t1Name, CalculationMode.Price, tp1);
            if (qtyT2 > 0)
            {
                SetStopLoss(t2Name, CalculationMode.Price, stop, false);
                SetProfitTarget(t2Name, CalculationMode.Price, tp2);
                runnerOrderStates[signalName] = new RunnerOrderState
                {
                    Feature = feature,
                    SignalName = signalName,
                    EntryNameT1 = t1Name,
                    EntryNameT2 = t2Name,
                    EntryPrice = entry,
                    Tp1Price = tp1,
                    RunnerQuantity = qtyT2,
                };
                t1EntryToSignal[t1Name] = signalName;
            }

            Order orderT1 = EnterLongLimit(0, true, qtyT1, entry, t1Name);
            TrackAnalyzerEntryOrder(t1Name, signalName, feature, orderT1);
            if (qtyT2 > 0)
            {
                Order orderT2 = EnterLongLimit(0, true, qtyT2, entry, t2Name);
                TrackAnalyzerEntryOrder(t2Name, signalName, feature, orderT2);
            }
        }

        private void TrackAnalyzerEntryOrder(string entryName, string signalName, Feature feature, Order order)
        {
            analyzerEntryOrders[entryName] = new AnalyzerEntryOrderState
            {
                Feature = feature,
                SignalName = signalName,
                EntryName = entryName,
                Order = order,
                SubmittedBarIndex = CurrentBar,
            };
            managedExecutionStates[entryName] = new ManagedExecutionState
            {
                Feature = feature,
                SignalName = signalName,
                EntryName = entryName,
            };
        }

        private Feature BuildFeature(ManciniLevel level, LevelRuntimeState state, bool requireReclaim)
        {
            if (state.TrapBarIndex < 0)
                return null;
            if (requireReclaim && state.ReclaimBarIndex < 0)
                return null;

            double setupLevel = level.Price;
            int trapIndex = state.TrapBarIndex;
            int reclaimIndex = state.ReclaimBarIndex >= 0 ? state.ReclaimBarIndex : CurrentBar;
            double sweptLow = MinimumLow(trapIndex, Math.Min(reclaimIndex, CurrentBar));
            double flushDepth = setupLevel - sweptLow;
            int recentStart = Math.Max(sessionStartBar, trapIndex - 30);
            int highIndex = HighestHighIndex(recentStart, trapIndex);
            double highPrice = BarHigh(highIndex);
            double medianVolume = MedianVolume(recentStart, trapIndex);
            double trapVolume = BarVolume(trapIndex);
            double minutesFromRecentHigh = Math.Max((BarTime(trapIndex) - BarTime(highIndex)).TotalMinutes, 1.0);
            double approachVelocity = (highPrice - sweptLow) / minutesFromRecentHigh;
            PriorStats prior = ComputePriorTouchStats(setupLevel, trapIndex);
            ReclaimMetrics reclaim = ComputeReclaimMetrics(setupLevel, reclaimIndex);

            double volumeRatioComponent = medianVolume > 0 ? Clamp(trapVolume / medianVolume, 0, 2) / 2.0 : 0.0;
            int multiLevelFlushCount = CountLevelsBetween(sweptLow, setupLevel);
            double significantLowScore =
                0.30 * Clamp(prior.PriorTouchCount / 3.0, 0, 1)
                + 0.25 * Clamp(prior.PriorHoldMinutes / 120.0, 0, 1)
                + 0.25 * Clamp(prior.PriorBouncePoints / 20.0, 0, 1)
                + 0.20 * level.MajorSourceBonus;

            double flushScore =
                0.35 * Clamp(flushDepth / 8.0, 0, 1)
                + 0.25 * Clamp(approachVelocity / 2.0, 0, 1)
                + 0.20 * Clamp(multiLevelFlushCount / 3.0, 0, 1)
                + 0.20 * volumeRatioComponent;

            double reclaimScore =
                0.25 * Indicator(CloseAt(reclaimIndex) > setupLevel)
                + 0.20 * Indicator(reclaim.ReclaimCloseLocation >= 0.5)
                + 0.20 * Clamp(reclaim.AcceptanceClosesUsedForScore / 3.0, 0, 1)
                + 0.20 * Indicator(reclaim.NoCloseBackBelowBeforeEntry)
                + 0.15 * Indicator(reclaim.ReclaimRange <= 6.0);

            double nonAcceptanceScore =
                0.40 * Indicator(reclaim.FirstThresholdCloseTime != DateTime.MinValue || reclaim.NonAcceptanceClosesUsedForScore > 0)
                + 0.30 * Clamp(reclaim.NonAcceptanceClosesUsedForScore / 3.0, 0, 1)
                + 0.20 * Indicator(reclaim.FirstRetestHolds)
                + 0.10 * 0.0;

            string timingDriver = nonAcceptanceScore >= reclaimScore && nonAcceptanceScore > 0.0
                ? "non_acceptance_score"
                : "reclaim_score";
            DateTime candidateFireTime = timingDriver == "non_acceptance_score"
                ? reclaim.NonAcceptanceScoreTime
                : reclaim.AcceptanceScoreTime;
            if (candidateFireTime == DateTime.MinValue)
                candidateFireTime = BarTime(reclaimIndex);
            int candidateFireIndex = BarIndexAtOrAfter(candidateFireTime);
            if (candidateFireIndex < 0 || candidateFireIndex > CurrentBar)
                return null;

            double entryPrice = setupLevel + Tick;
            double plannedStop = setupLevel - StopBelowLevelPoints;
            ManciniLevel targetLevel = NextLevelAbove(entryPrice);
            double targetRoom = targetLevel == null ? double.NaN : targetLevel.Price - entryPrice;
            double riskToStop = entryPrice - plannedStop;
            double targetR = double.IsNaN(targetRoom) ? double.NaN : targetRoom / Math.Max(riskToStop, Tick);
            string bucket = TimeBucket(candidateFireTime);
            string nextSource = targetLevel == null ? string.Empty : (targetLevel.SourceKind ?? string.Empty).ToLowerInvariant();
            bool trustedSource = nextSource.IndexOf("mancini", StringComparison.Ordinal) >= 0
                || nextSource.IndexOf("bobby", StringComparison.Ordinal) >= 0
                || nextSource.IndexOf("gex", StringComparison.Ordinal) >= 0
                || nextSource.IndexOf("dubz", StringComparison.Ordinal) >= 0
                || nextSource.IndexOf("saty", StringComparison.Ordinal) >= 0
                || nextSource.IndexOf("protocol", StringComparison.Ordinal) >= 0
                || nextSource.IndexOf("daily_plan_text", StringComparison.Ordinal) >= 0;
            bool noTrustedLevelWithinTwo = !double.IsNaN(targetRoom) && targetRoom > 2.0;

            double squeezeScore =
                0.30 * Clamp(double.IsNaN(targetRoom) ? 0 : targetRoom / 8.0, 0, 1)
                + 0.25 * Clamp(double.IsNaN(targetR) ? 0 : targetR / 2.0, 0, 1)
                + 0.20 * Indicator(trustedSource)
                + 0.15 * Indicator(noTrustedLevelWithinTwo)
                + 0.10 * TimeBonus(bucket);

            double candidateScore =
                0.25 * significantLowScore
                + 0.20 * flushScore
                + 0.25 * Math.Max(reclaimScore, nonAcceptanceScore)
                + 0.20 * squeezeScore
                + 0.10 * level.SourceConfidence;

            string family = AcceptanceFamily(state.FirstReclaimFailed, multiLevelFlushCount, flushDepth, reclaim.AcceptanceClosesUsedForScore, nonAcceptanceScore);

            return new Feature
            {
                Level = level,
                SessionDate = activeSessionDate,
                SetupLevel = setupLevel,
                SweptLow = sweptLow,
                TrapTime = state.TrapTime,
                ReclaimTime = state.ReclaimTime,
                ClassificationCompleteTime = candidateFireTime,
                CandidateFiredTime = candidateFireTime,
                CandidateTimingDriver = timingDriver,
                EntryPrice = entryPrice,
                EntryTimestamp = candidateFireTime,
                AcceptanceFamilyModel = family,
                SignificantLowScore = significantLowScore,
                FlushScore = flushScore,
                ReclaimScore = reclaimScore,
                NonAcceptanceScore = nonAcceptanceScore,
                NonAcceptanceCloses = reclaim.NonAcceptanceClosesUsedForScore,
                CandidateScore = candidateScore,
                TargetRoom = targetRoom,
                RiskToSweep = riskToStop,
                TargetR = targetR,
                NextTrustedLevelAbove = targetLevel == null ? double.NaN : targetLevel.Price,
                NextTrustedLevelSource = targetLevel == null ? string.Empty : targetLevel.SourceKind,
                NextTrustedLevelRole = targetLevel == null ? string.Empty : targetLevel.PrimaryRole,
                TimeOfDayBucket = bucket,
                FirstReclaimFailedBeforeCandidate = state.FirstReclaimFailed,
            };
        }

        private bool RuleMatches(Feature feature)
        {
            return string.Equals(feature.AcceptanceFamilyModel, "non_acceptance_protocol", StringComparison.Ordinal)
                && feature.CandidateScore >= MinimumCandidateScore
                && feature.NonAcceptanceScore >= MinimumNonAcceptanceScore
                && feature.RiskToSweep <= HardStopRiskGatePoints;
        }

        private double PlannedEntryPrice(Feature feature)
        {
            return feature.SetupLevel + Tick;
        }

        private double PlannedStopPrice(Feature feature)
        {
            return feature.SetupLevel - StopBelowLevelPoints;
        }

        private double PlannedTp1Price(double entry)
        {
            return entry + Tp1Points;
        }

        private double PlannedTp2Price(Feature feature, double entry, double tp1)
        {
            if (!double.IsNaN(feature.NextTrustedLevelAbove) && feature.NextTrustedLevelAbove > tp1)
                return feature.NextTrustedLevelAbove;
            return entry + RunnerFallbackPoints;
        }

        private void ProcessPendingSignals()
        {
            for (int i = pendingSignals.Count - 1; i >= 0; i--)
            {
                PendingSignal pending = pendingSignals[i];
                if (CurrentBar <= pending.SignalBarIndex)
                    continue;
                if (!pending.OrdersSubmitted && CanSubmitAnalyzerOrder())
                {
                    SubmitAnalyzerOrders(pending.SignalName, pending.Feature);
                    pending.OrdersSubmitted = true;
                }
                if (CurrentBar - pending.SignalBarIndex > Math.Max(1, LimitFillTimeoutBars))
                {
                    WriteTelemetry("NO_FILL", pending.Feature, null, "signal=" + pending.SignalName + " pine_limit_not_touched_within_bars=" + Math.Max(1, LimitFillTimeoutBars).ToString(CultureInfo.InvariantCulture));
                    CancelAnalyzerEntryOrdersForSignal(pending.SignalName, pending.Feature, "pine_limit_timeout_no_fill");
                    pendingSignals.RemoveAt(i);
                    continue;
                }

                double entry = PlannedEntryPrice(pending.Feature);
                if (Low[0] > entry || High[0] < entry)
                    continue;

                int contracts = Math.Max(1, AnalyzerQuantity);
                int tp1Contracts = contracts;
                int runnerContracts = 0;
                if (SplitTp1Tp2Runner && contracts >= 2)
                {
                    tp1Contracts = Math.Max(1, contracts / 2);
                    runnerContracts = contracts - tp1Contracts;
                }
                double stop = PlannedStopPrice(pending.Feature);
                double tp1 = PlannedTp1Price(entry);
                ActiveSimulation simulation = new ActiveSimulation
                {
                    Feature = pending.Feature,
                    SignalName = pending.SignalName,
                    EntryBarIndex = CurrentBar,
                    EntryTime = Time[0],
                    EntryPrice = entry,
                    ActiveStopPrice = stop,
                    InitialStopPrice = stop,
                    Tp1Price = tp1,
                    Tp2Price = PlannedTp2Price(pending.Feature, entry, tp1),
                    Contracts = contracts,
                    Tp1Contracts = tp1Contracts,
                    RunnerContracts = runnerContracts,
                    RemainingContracts = contracts,
                };
                activeSimulations.Add(simulation);
                WriteTelemetry("ENTRY", pending.Feature, simulation, "signal=" + pending.SignalName + " pine_next_bar_limit_fill");
                pendingSignals.RemoveAt(i);
            }
        }

        private void CancelExpiredAnalyzerEntryOrders()
        {
            if (analyzerEntryOrders.Count == 0)
                return;

            int timeoutBars = Math.Max(1, LimitFillTimeoutBars);
            List<AnalyzerEntryOrderState> expired = new List<AnalyzerEntryOrderState>();
            foreach (KeyValuePair<string, AnalyzerEntryOrderState> item in analyzerEntryOrders)
            {
                AnalyzerEntryOrderState state = item.Value;
                if (state.CancelRequested || CurrentBar - state.SubmittedBarIndex <= timeoutBars)
                    continue;
                expired.Add(state);
            }

            for (int i = 0; i < expired.Count; i++)
                CancelAnalyzerEntryOrder(expired[i], "limit_timeout_bars=" + timeoutBars.ToString(CultureInfo.InvariantCulture));
        }

        private void CancelAnalyzerEntryOrdersForSignal(string signalName, Feature feature, string reason)
        {
            List<AnalyzerEntryOrderState> matches = new List<AnalyzerEntryOrderState>();
            foreach (KeyValuePair<string, AnalyzerEntryOrderState> item in analyzerEntryOrders)
            {
                if (string.Equals(item.Value.SignalName, signalName, StringComparison.Ordinal))
                    matches.Add(item.Value);
            }

            for (int i = 0; i < matches.Count; i++)
                CancelAnalyzerEntryOrder(matches[i], reason);
            if (matches.Count == 0)
                WriteTelemetry("ORDER_CANCEL_SKIPPED", feature, null, "signal=" + signalName + " reason=" + reason + " active_entry_orders=0");
        }

        private void CancelAllAnalyzerEntryOrders(string reason)
        {
            if (analyzerEntryOrders.Count == 0)
                return;

            List<AnalyzerEntryOrderState> orders = new List<AnalyzerEntryOrderState>(analyzerEntryOrders.Values);
            for (int i = 0; i < orders.Count; i++)
                CancelAnalyzerEntryOrder(orders[i], reason);
        }

        private void CancelAnalyzerEntryOrder(AnalyzerEntryOrderState state, string reason)
        {
            state.CancelRequested = true;
            if (IsActive(state.Order))
            {
                CancelOrder(state.Order);
                WriteTelemetry("ORDER_CANCEL_REQUESTED", state.Feature, null, "signal=" + state.SignalName + " order=" + state.EntryName + " reason=" + reason);
                return;
            }

            analyzerEntryOrders.Remove(state.EntryName);
            WriteTelemetry("ORDER_CANCEL_SKIPPED", state.Feature, null, "signal=" + state.SignalName + " order=" + state.EntryName + " reason=" + reason + " order_not_active");
        }

        private void ProcessActiveSimulations()
        {
            for (int i = activeSimulations.Count - 1; i >= 0; i--)
            {
                ActiveSimulation simulation = activeSimulations[i];
                bool hitStop = Low[0] <= simulation.ActiveStopPrice;
                bool hitTp1 = High[0] >= simulation.Tp1Price;
                bool hitTp2 = simulation.RunnerContracts > 0 && High[0] >= simulation.Tp2Price;
                bool timedOut = CurrentBar - simulation.EntryBarIndex > Math.Max(1, OutcomeHorizonBars);
                if (!hitStop && !hitTp1 && !hitTp2 && !timedOut)
                    continue;

                simulation.FirstHitTimestamp = Time[0];
                if (!simulation.Tp1Hit)
                {
                    simulation.SameBarStopAndTarget = hitStop && (hitTp1 || hitTp2);
                    double riskPoints = simulation.EntryPrice - simulation.InitialStopPrice;
                    if (hitStop && (hitTp1 || hitTp2))
                    {
                        simulation.FirstHitEvent = "same_bar_stop_first_before_tp1";
                        simulation.GrossContractPoints += -riskPoints * simulation.RemainingContracts;
                        simulation.RemainingContracts = 0;
                        simulation.StopFirst = true;
                    }
                    else if (hitStop)
                    {
                        simulation.FirstHitEvent = "stop_before_tp1";
                        simulation.GrossContractPoints += -riskPoints * simulation.RemainingContracts;
                        simulation.RemainingContracts = 0;
                        simulation.StopFirst = true;
                    }
                    else if (hitTp2 && simulation.RunnerContracts > 0)
                    {
                        simulation.FirstHitEvent = "tp2_before_tp1_branch";
                        simulation.GrossContractPoints += Tp1Points * simulation.Tp1Contracts
                            + (simulation.Tp2Price - simulation.EntryPrice) * simulation.RunnerContracts;
                        simulation.RemainingContracts = 0;
                        simulation.TargetFirst = true;
                    }
                    else if (hitTp1)
                    {
                        simulation.FirstHitEvent = "tp1";
                        simulation.Tp1Hit = true;
                        simulation.GrossContractPoints += Tp1Points * simulation.Tp1Contracts;
                        simulation.RemainingContracts = simulation.RunnerContracts;
                        simulation.ActiveStopPrice = simulation.EntryPrice;
                        simulation.TargetFirst = true;
                    }
                    else if (timedOut)
                    {
                        simulation.FirstHitEvent = "timeout_close";
                        simulation.GrossContractPoints += (Close[0] - simulation.EntryPrice) * simulation.RemainingContracts;
                        simulation.RemainingContracts = 0;
                    }
                }
                else
                {
                    bool hitRunnerStop = Low[0] <= simulation.ActiveStopPrice;
                    bool hitRunnerTarget = High[0] >= simulation.Tp2Price;
                    if (hitRunnerTarget)
                    {
                        simulation.FirstHitEvent = "tp1_then_tp2";
                        simulation.GrossContractPoints += (simulation.Tp2Price - simulation.EntryPrice) * simulation.RemainingContracts;
                        simulation.RemainingContracts = 0;
                    }
                    else if (hitRunnerStop)
                    {
                        simulation.FirstHitEvent = "tp1_then_runner_be";
                        simulation.RemainingContracts = 0;
                    }
                    else if (timedOut)
                    {
                        simulation.FirstHitEvent = "tp1_then_timeout_close";
                        simulation.GrossContractPoints += (Close[0] - simulation.EntryPrice) * simulation.RemainingContracts;
                        simulation.RemainingContracts = 0;
                    }
                }
                if (simulation.RemainingContracts <= 0)
                {
                    simulation.FirstHitPoints = simulation.GrossContractPoints;
                    double netContractPoints = simulation.GrossContractPoints - AccountingCostPointsPerContract * simulation.Contracts;
                    WriteTelemetry("OUTCOME", simulation.Feature, simulation, "signal=" + simulation.SignalName + " net_contract_points_after_cost=" + Format(netContractPoints));
                    activeSimulations.RemoveAt(i);
                }
            }
        }

        private void ProcessManagedTimeoutExits()
        {
            if (managedExecutionStates.Count == 0)
                return;

            int timeoutBars = Math.Max(1, OutcomeHorizonBars);
            List<ManagedExecutionState> timedOut = new List<ManagedExecutionState>();
            foreach (KeyValuePair<string, ManagedExecutionState> item in managedExecutionStates)
            {
                ManagedExecutionState state = item.Value;
                if (state.TimeoutExitRequested || state.EntryQuantity <= state.ExitQuantity || state.EntryBarIndex < 0)
                    continue;
                if (CurrentBar - state.EntryBarIndex <= timeoutBars)
                    continue;
                timedOut.Add(state);
            }

            for (int i = 0; i < timedOut.Count; i++)
            {
                ManagedExecutionState state = timedOut[i];
                int quantityToExit = Math.Max(0, state.EntryQuantity - state.ExitQuantity);
                if (quantityToExit <= 0)
                    continue;

                state.TimeoutExitRequested = true;
                string timeoutExitName = "MFBDTimeout" + state.EntryName;
                ExitLong(0, quantityToExit, timeoutExitName, state.EntryName);
                WriteTelemetry("MANAGED_TIMEOUT_EXIT_SUBMITTED", state.Feature, null,
                    "signal=" + state.SignalName
                    + " entry_order=" + state.EntryName
                    + " exit_order=" + timeoutExitName
                    + " quantity=" + quantityToExit.ToString(CultureInfo.InvariantCulture)
                    + " timeout_bars=" + timeoutBars.ToString(CultureInfo.InvariantCulture));
            }
        }

        private void TrackManagedExecution(Execution execution, double price, int quantity, DateTime time)
        {
            Order order = execution.Order;
            string orderName = order.Name ?? string.Empty;
            string fromEntrySignal = order.FromEntrySignal ?? string.Empty;
            if (order.OrderAction == OrderAction.Buy)
            {
                ManagedExecutionState state;
                if (!managedExecutionStates.TryGetValue(orderName, out state))
                    return;

                int previousQuantity = state.EntryQuantity;
                state.EntryPrice = WeightedAverage(state.EntryPrice, previousQuantity, price, quantity);
                state.EntryQuantity += quantity;
                if (previousQuantity <= 0)
                    state.EntryBarIndex = CurrentBar;
                state.EntryTime = time;
                WriteTelemetry("MANAGED_ENTRY_EXECUTION", state.Feature, null,
                    "signal=" + state.SignalName
                    + " order=" + orderName
                    + " execution_time=" + FormatDate(time)
                    + " price=" + Format(price)
                    + " quantity=" + quantity.ToString(CultureInfo.InvariantCulture));
                return;
            }

            if (order.OrderAction != OrderAction.Sell)
                return;

            ManagedExecutionState exitState;
            string resolvedEntrySignal = fromEntrySignal;
            if (!managedExecutionStates.TryGetValue(fromEntrySignal, out exitState))
            {
                if (!TryResolveSingleOpenManagedExit(fromEntrySignal, out resolvedEntrySignal, out exitState))
                {
                    WriteTelemetry("MANAGED_EXIT_UNMATCHED", null, null,
                        "from_entry=" + fromEntrySignal
                        + " order=" + orderName
                        + " execution_time=" + FormatDate(time)
                        + " price=" + Format(price)
                        + " quantity=" + quantity.ToString(CultureInfo.InvariantCulture));
                    return;
                }
            }
            if (exitState.EntryQuantity <= 0)
            {
                WriteTelemetry("MANAGED_EXIT_BEFORE_ENTRY", exitState.Feature, null,
                    "signal=" + exitState.SignalName
                    + " entry_order=" + exitState.EntryName
                    + " exit_order=" + orderName
                    + " from_entry=" + fromEntrySignal
                    + " execution_time=" + FormatDate(time)
                    + " exit_price=" + Format(price)
                    + " quantity=" + quantity.ToString(CultureInfo.InvariantCulture));
                return;
            }

            double grossPoints = (price - exitState.EntryPrice) * quantity;
            exitState.ExitQuantity += quantity;
            exitState.ExitPrice = price;
            exitState.ExitTime = time;
            exitState.GrossContractPoints += grossPoints;
            bool complete = exitState.EntryQuantity > 0 && exitState.ExitQuantity >= exitState.EntryQuantity;
            double netPoints = exitState.GrossContractPoints - AccountingCostPointsPerContract * exitState.EntryQuantity;
            WriteTelemetry(complete ? "MANAGED_OUTCOME" : "MANAGED_EXIT_EXECUTION", exitState.Feature, null,
                "signal=" + exitState.SignalName
                + " entry_order=" + exitState.EntryName
                + " exit_order=" + orderName
                + " from_entry=" + fromEntrySignal
                + " resolved_from_entry=" + resolvedEntrySignal
                + " execution_time=" + FormatDate(time)
                + " exit_price=" + Format(price)
                + " quantity=" + quantity.ToString(CultureInfo.InvariantCulture)
                + " entry_price=" + Format(exitState.EntryPrice)
                + " gross_contract_points=" + Format(exitState.GrossContractPoints)
                + " net_contract_points_after_cost=" + Format(netPoints));
            if (complete)
                managedExecutionStates.Remove(resolvedEntrySignal);
        }

        private bool TryResolveSingleOpenManagedExit(string fromEntrySignal, out string resolvedEntrySignal, out ManagedExecutionState exitState)
        {
            resolvedEntrySignal = string.Empty;
            exitState = null;
            if (!string.IsNullOrWhiteSpace(fromEntrySignal))
                return false;

            int openCount = 0;
            foreach (KeyValuePair<string, ManagedExecutionState> item in managedExecutionStates)
            {
                ManagedExecutionState candidate = item.Value;
                if (candidate.EntryQuantity <= candidate.ExitQuantity)
                    continue;
                openCount++;
                resolvedEntrySignal = item.Key;
                exitState = candidate;
                if (openCount > 1)
                {
                    resolvedEntrySignal = string.Empty;
                    exitState = null;
                    return false;
                }
            }
            return openCount == 1 && exitState != null;
        }

        private bool CanSubmitAnalyzerOrder()
        {
            if (!SubmitHistoricalAnalyzerOrders)
                return false;
            if (State == State.Historical)
                return true;
            return State == State.Realtime && AllowRealtimePlaybackSim && IsPermittedRealtimeAccount();
        }

        private bool IsPermittedRealtimeAccount()
        {
            string name = Account == null ? string.Empty : (Account.Name ?? string.Empty).Trim();
            if (name.StartsWith("Sim", StringComparison.OrdinalIgnoreCase)
                || name.StartsWith("Playback", StringComparison.OrdinalIgnoreCase))
                return true;

            if (string.IsNullOrWhiteSpace(PermittedRealtimeAccounts))
                return false;

            string[] permitted = PermittedRealtimeAccounts.Split(new char[] { ',', ';' }, StringSplitOptions.RemoveEmptyEntries);
            for (int i = 0; i < permitted.Length; i++)
            {
                if (string.Equals(name, permitted[i].Trim(), StringComparison.OrdinalIgnoreCase))
                    return true;
            }
            return false;
        }

        private static bool IsActive(Order order)
        {
            if (order == null)
                return false;
            return order.OrderState == OrderState.Accepted
                || order.OrderState == OrderState.Submitted
                || order.OrderState == OrderState.Working
                || order.OrderState == OrderState.PartFilled;
        }

