        private int HighestHighIndex(int start, int end)
        {
            int chosen = start;
            double high = double.MinValue;
            for (int index = start; index <= end; index++)
            {
                if (BarHigh(index) > high)
                {
                    high = BarHigh(index);
                    chosen = index;
                }
            }
            return chosen;
        }

        private double MinimumLow(int start, int end)
        {
            double low = double.MaxValue;
            for (int index = start; index <= end; index++)
                low = Math.Min(low, BarLow(index));
            return low == double.MaxValue ? Low[0] : low;
        }

        private double MedianVolume(int start, int end)
        {
            List<double> values = new List<double>();
            for (int index = start; index <= end; index++)
                values.Add(BarVolume(index));
            if (values.Count == 0)
                return 0.0;
            values.Sort();
            int mid = values.Count / 2;
            if (values.Count % 2 == 1)
                return values[mid];
            return (values[mid - 1] + values[mid]) / 2.0;
        }

        private int BarIndexAtOrAfter(DateTime timestamp)
        {
            for (int index = sessionStartBar; index <= CurrentBar; index++)
            {
                if (BarTime(index) >= timestamp)
                    return index;
            }
            return -1;
        }

