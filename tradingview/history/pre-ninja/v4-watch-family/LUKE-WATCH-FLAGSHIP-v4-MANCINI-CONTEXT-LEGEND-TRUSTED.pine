require_confirmed_signal_bar = signal_timing_mode == "confirmed_5m"
ltf_fill_validation_mode = input.string("1m", "Fill validation", options=["off", "1m", "3m", "5m_chart", "either_1m_or_3m", "both_1m_and_3m", "any_1m_3m_5m", "all_1m_3m_5m"], tooltip="1m and 3m use lower-timeframe OHLC arrays. 5m_chart uses the current chart candle OHLC as a coarser fallback.")
ltf_enforcement_mode = input.string("gate_alerts_and_accounting", "LTF enforcement", options=["audit_only", "gate_alerts_and_accounting"], tooltip="audit_only keeps v4 behavior and labels reasons. gate_alerts_and_accounting only starts a LONG when the LTF validation passes.")
show_ltf_audit_labels = input.bool(false, "Show LTF audit labels")
