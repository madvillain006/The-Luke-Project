f_add_entry_signal_label(label[] labels, int x, float y, string entry_text) =>
    label entry_label = label.new(x, y, entry_text, style=label.style_label_up, textcolor=color.white, color=color.new(color.green, 8), size=size.small)
    array.push(labels, entry_label)
    if array.size(labels) > 40
        label old_entry_label = array.shift(labels)
        label.delete(old_entry_label)
    entry_label

f_update_entry_signal_label(label entry_label, string entry_text, string result_text, color result_color) =>
    if not na(entry_label)
        label.set_text(entry_label, entry_text + "\n" + result_text)
        label.set_color(entry_label, result_color)

f_add_status_label(label[] labels, int x, float y, string status_text, color status_color) =>
    array.push(labels, label.new(x, y, status_text, style=label.style_label_up, textcolor=color.white, color=status_color, size=size.tiny))
    if array.size(labels) > 40
        label old_label = array.shift(labels)
        label.delete(old_label)

f_add_watch_label(label[] labels, int x, float y, string watch_text) =>
    label watch_label = label.new(x, y, watch_text, style=label.style_label_up, textcolor=color.white, color=color.new(color.gray, 20), size=size.tiny)
    array.push(labels, watch_label)
    if array.size(labels) > watch_label_history_limit
        label old_watch_label = array.shift(labels)
        label.delete(old_watch_label)
    watch_label

f_add_cancel_watch_label(label[] labels, int x, float y, string watch_text) =>
    label watch_label = label.new(x, y, watch_text, style=label.style_label_up, textcolor=color.white, color=color.new(color.orange, 15), size=size.tiny)
    array.push(labels, watch_label)
    if array.size(labels) > watch_label_history_limit
        label old_watch_label = array.shift(labels)
        label.delete(old_watch_label)
    watch_label

f_draw_mancini_context_levels(line[] lines, label[] labels, string raw, string tag, color context_color, int context_width) =>
    string[] parts = str.split(raw, ",")
    if array.size(parts) > 0
        for context_i = 0 to array.size(parts) - 1
            string part = str.trim(array.get(parts, context_i))
            float level = str.tonumber(part)
            bool in_display_window = not na(level) and (level_display_window_points <= 0.0 or math.abs(level - close) <= level_display_window_points)
            if in_display_window
                array.push(lines, line.new(bar_index - 100, level, bar_index + 1, level, extend=extend.right, color=context_color, width=context_width))
                if show_mancini_context_labels
                    string context_label_text = str.tostring(level, format.mintick) + " " + tag
                    array.push(labels, label.new(bar_index + 1, level, context_label_text, style=label.style_label_left, textcolor=color.white, color=color.new(context_color, 20), size=size.tiny))

f_signed_points(float value) =>
    na(value) ? "n/a" : (value > 0 ? "+" : "") + str.tostring(value, "#.##") + "pt"

f_money(float value) =>
    na(value) ? "n/a" : (value > 0 ? "+$" : value < 0 ? "-$" : "$") + str.tostring(math.abs(value), "#.##")

f_et_time_from_timestamp(int timestamp_value) =>
    string minute_text = minute(timestamp_value, "America/New_York") < 10 ? "0" + str.tostring(minute(timestamp_value, "America/New_York")) : str.tostring(minute(timestamp_value, "America/New_York"))
    str.tostring(hour(timestamp_value, "America/New_York")) + ":" + minute_text + " ET"

f_mixed_realized_points(float stop_price, float entry_price, float target_price) =>
    mixed_bar_pnl_policy == "target_first" ? target_price - entry_price : mixed_bar_pnl_policy == "zero" ? 0.0 : stop_price - entry_price

f_entry_slippage_points() =>
    realistic_accounting_mode == "entry_only_0_25" ? 0.25 : realistic_accounting_mode == "both_sides_0_25_each" ? 0.25 : realistic_accounting_mode == "custom_entry_only" ? custom_slippage_points : realistic_accounting_mode == "custom_both_sides" ? custom_slippage_points : 0.0

f_exit_slippage_points() =>
    realistic_accounting_mode == "exit_only_0_25" ? 0.25 : realistic_accounting_mode == "both_sides_0_25_each" ? 0.25 : realistic_accounting_mode == "custom_exit_only" ? custom_slippage_points : realistic_accounting_mode == "custom_both_sides" ? custom_slippage_points : 0.0

f_round_trip_slippage_points() =>
    f_entry_slippage_points() + f_exit_slippage_points()

f_accounting_entry(float entry_price) =>
    entry_price + f_entry_slippage_points()

f_event_cost_dollars(float contracts) =>
    size_mode == "watch only" ? 0.0 : ((f_round_trip_slippage_points() * pnl_dollars_per_point) + commission_per_contract_round_trip) * contracts

f_session_commission_dollars() =>
    float cost_per_contract = (f_round_trip_slippage_points() * pnl_dollars_per_point) + commission_per_contract_round_trip
    cost_per_contract > 0 ? session_cost_dollars * commission_per_contract_round_trip / cost_per_contract : 0.0

f_session_slippage_dollars() =>
    session_cost_dollars - f_session_commission_dollars()

f_event_net_dollars(float event_points, float contracts) =>
    event_points * pnl_dollars_per_point - f_event_cost_dollars(contracts)

f_open_contract_count(bool tp1_already_hit) =>
    size_mode == "watch only" ? 0.0 : split_contract_pnl and not tp1_already_hit ? 2.0 : 1.0

f_tp1_partial_contract_count() =>
    size_mode == "watch only" ? 0.0 : split_contract_pnl ? 1.0 : 0.0

f_mixed_tp1_contract_count() =>
    size_mode == "watch only" ? 0.0 : split_contract_pnl ? mixed_bar_pnl_policy == "target_first" ? 1.0 : mixed_bar_pnl_policy == "zero" ? 0.0 : 2.0 : 1.0

if new_futures_session
    session_attempts := 0
    session_successes := 0
    session_stopped := 0
    session_watches := 0
    session_tp1_hits := 0
    session_tp2_hits := 0
    session_breakevens := 0
    session_mixed := 0
    session_refreshed := 0
    session_ltf_filtered := 0
    session_live_cancelled := 0
    session_realized_points := 0.0
    session_realized_dollars := 0.0
    session_cost_dollars := 0.0
    session_net_dollars := 0.0
    tracked_candidate_trade_net_dollars := 0.0
    candidate_id := 0
    watch_id := 0
    last_candidate_closed_bar := na
    last_failed_candidate_bar := na
    last_failed_candidate_level := na
    tracked_candidate_open := false
    tracked_candidate_tp1_hit := false
    tracked_candidate_success_counted := false
    live_pending_long := false
    live_pending_bar := na
    live_pending_text := ""
    live_pending_y := na
    live_pending_level := na
    live_pending_entry := na
    live_pending_label := na
    live_cancelled_this_bar := false
    live_cancelled_bar := na
    live_cancelled_text := ""
    live_cancelled_y := na
    live_cancelled_label := na
    array.clear(live_cancelled_texts)
    array.clear(live_cancelled_ys)

if barstate.isnew and live_cancelled_bar != bar_index
    live_cancelled_this_bar := false
    live_cancelled_bar := na
    live_cancelled_text := ""
    live_cancelled_y := na
    live_cancelled_label := na
    array.clear(live_cancelled_texts)
    array.clear(live_cancelled_ys)

if barstate.islast
    if array.size(level_lines) > 0
        for i = 0 to array.size(level_lines) - 1
            line.delete(array.get(level_lines, i))
    if array.size(level_labels) > 0
        for i = 0 to array.size(level_labels) - 1
            label.delete(array.get(level_labels, i))
    array.clear(level_lines)
    array.clear(level_labels)

    if not na(warning_label)
        label.delete(warning_label)
    string warning_text = cluster_tolerance_raw > 3.0 ? "Tolerance capped at 3.0" : ""
    if str.length(warning_text) > 0
        warning_label := label.new(bar_index, high, warning_text, style=label.style_label_down, textcolor=color.white, color=color.new(color.orange, 0))

    if array.size(cluster_prices) > 0 and max_displayed_cluster_lines > 0
        int drawn_levels = 0
        for i = 0 to array.size(cluster_prices) - 1
            float level = array.get(cluster_prices, i)
            int strength = array.get(cluster_strengths, i)
            string sources = array.get(cluster_labels, i)
            bool in_display_window = level_display_window_points <= 0.0 or math.abs(level - close) <= level_display_window_points
            if drawn_levels < max_displayed_cluster_lines and in_display_window
                bool has_saty = str.contains(sources, "saty")
                bool has_mancini = str.contains(sources, "mancini")
                color line_color = has_saty and has_mancini ? color.new(color.yellow, 0) : has_saty ? color.new(color.lime, 10) : has_mancini ? color.new(color.blue, 8) : strength >= 3 ? color.new(color.yellow, 0) : strength == 2 ? color.new(color.aqua, 15) : color.new(color.gray, 35)
                int width = has_saty or has_mancini or strength >= 3 ? 2 : strength == 2 ? 2 : 1
                array.push(level_lines, line.new(bar_index - 100, level, bar_index + 1, level, extend=extend.right, color=line_color, width=width))
                drawn_levels += 1
                if show_cluster_labels
                    string cluster_label_text = show_source_labels ? str.tostring(level, format.mintick) + " " + sources : str.tostring(level, format.mintick)
                    array.push(level_labels, label.new(bar_index + 1, level, cluster_label_text, style=label.style_label_left, textcolor=color.white, color=color.new(color.black, 55), size=size.tiny))
        if enable_mancini
            f_draw_mancini_context_levels(level_lines, level_labels, mancini_major_levels_input, "M MAJOR", color.new(color.aqua, 0), 3)
            f_draw_mancini_context_levels(level_lines, level_labels, mancini_focus_long_levels_input, "M FOCUS LONG", color.new(color.orange, 0), 3)
            f_draw_mancini_context_levels(level_lines, level_labels, mancini_reclaim_trigger_levels_input, "M RECLAIM/TRIGGER", color.new(color.fuchsia, 0), 3)
            f_draw_mancini_context_levels(level_lines, level_labels, mancini_target_only_levels_input, "M TARGET ONLY", color.new(color.purple, 0), 2)
            f_draw_mancini_context_levels(level_lines, level_labels, mancini_caution_levels_input, "M READ REACTION", color.new(color.gray, 0), 2)

bool watch_signal = false
bool armed_signal = false
bool paper_signal = false
bool invalidated_signal = false
bool raw_flush_signal = false
bool raw_reclaim_signal = false
bool blocked_signal = false
float active_entry = na
float active_stop = na
float active_tp1 = na
float active_tp2 = na
float active_level = na
string active_block_reason = ""
float paper_level = na
float paper_entry = na
float paper_stop = na
float paper_tp1 = na
float paper_tp2 = na
float armed_level = na
float armed_entry = na
float armed_stop = na
float armed_tp1 = na
float armed_tp2 = na
float watch_level = na
float watch_entry = na
float watch_stop = na
float watch_tp1 = na
float watch_tp2 = na
bool paper_fresh_retest = false
bool paper_failed_chase_block = false

if enable_luke_levels and enable_reclaim_signals and array.size(cluster_prices) > 0
    for i = 0 to array.size(cluster_prices) - 1
        float level = array.get(cluster_prices, i)
        float next_cluster = f_next_above(cluster_prices, level)
        float target_space = na(next_cluster) ? tp1_points * 2.0 : next_cluster - level
        float candidate_entry = entry_price_mode == "signal_close" ? close : level + math.max(min_close_above_level_points, syminfo.mintick)
        float candidate_stop = level - math.min(max_stop_points, hard_stop_points)
        float candidate_tp1 = candidate_entry + tp1_points
        float candidate_tp2 = tp2_mode == "next_cluster" and not na(next_cluster) and next_cluster > candidate_tp1 ? next_cluster : candidate_entry + tp1_points * 2.0
        bool recent_level_tap = false
        for tap_bar = 0 to level_tap_lookback_bars
            bool tapped = low[tap_bar] <= level + level_tap_tolerance_points and high[tap_bar] >= level - syminfo.mintick
            recent_level_tap := recent_level_tap or tapped
        bool fresh_level_retest = recent_level_tap and close >= level + min_close_above_level_points
        bool failed_level_recent = not na(last_failed_candidate_level) and not na(last_failed_candidate_bar) and math.abs(level - last_failed_candidate_level) <= failed_reentry_level_tolerance_points and bar_index - last_failed_candidate_bar <= failed_reentry_cooldown_bars
        bool failed_level_reset = low <= level - failed_reentry_reset_points and close >= level + min_close_above_level_points
        bool failed_chase_block = failed_level_recent and not failed_level_reset
        bool flush_event = low <= level - syminfo.mintick and close[1] >= level
        bool reclaim_event = close > level and (close[1] <= level or low <= level - syminfo.mintick)
        int bars_since_flush = -1
        int bars_since_reclaim = -1
        for lookback = 0 to flush_lookback_bars
            bool past_flush = low[lookback] <= level - syminfo.mintick and close[lookback + 1] >= level
            bool past_reclaim = close[lookback] > level and (close[lookback + 1] <= level or low[lookback] <= level - syminfo.mintick)
            if bars_since_flush == -1 and past_flush
                bars_since_flush := lookback
            if bars_since_reclaim == -1 and past_reclaim
                bars_since_reclaim := lookback
        bool flush_before_reclaim = bars_since_flush >= 0 and bars_since_reclaim >= 0 and (bars_since_flush > bars_since_reclaim or (bars_since_flush == 0 and bars_since_reclaim == 0))
        bool reclaim_recent = flush_before_reclaim and bars_since_flush <= flush_lookback_bars and bars_since_reclaim <= flush_lookback_bars
        bool hold_above = true
        for hold_bar = 0 to reclaim_hold_bars - 1
            hold_above := hold_above and close[hold_bar] >= level
        float entry_target_space = na(next_cluster) ? tp1_points * 2.0 : next_cluster - candidate_entry
        float candle_range = math.max(high - low, syminfo.mintick)
        float reclaim_close_location = (close - low) / candle_range
        float reclaim_body_pct = math.abs(close - open) / candle_range
        float reclaim_upper_wick = high - math.max(open, close)
        bool close_cleared_level = close >= level + min_close_above_level_points
        bool not_stuffed_reclaim = not anti_stuff_filter or (close_cleared_level and reclaim_close_location >= min_reclaim_close_location and reclaim_upper_wick <= max_reclaim_upper_wick_points and pivot_ribbon_long_ok)
        bool impulse_cloud_ok = not require_impulse_cloud_break or pivot_cloud_break_now or close >= pivot_cloud_top
        bool impulse_reclaim_here = enable_impulse_reclaim_long and reclaim_event and fresh_level_retest and close > open and reclaim_body_pct >= min_impulse_body_pct and close_cleared_level and impulse_cloud_ok and pivot_ribbon_long_ok
        float candidate_risk_points = candidate_entry - candidate_stop
        bool risk_ok = candidate_risk_points <= hard_stop_points
        bool tp1_room_ok = allow_tp1_room_candidate and (na(next_cluster) or next_cluster - candidate_entry >= tp1_points)
        bool target_ok = (target_space >= min_target_space_points and entry_target_space >= min_target_space_points) or tp1_room_ok
        bool watch_here = flush_event and target_ok
        bool armed_here = ((reclaim_recent and hold_above) or impulse_reclaim_here) and target_ok and not_stuffed_reclaim and not failed_chase_block
        bool paper_here = armed_here and risk_ok
        bool invalid_here = reclaim_recent and close < level - syminfo.mintick and close[1] >= level
        bool blocked_here = reclaim_recent and hold_above and (not target_ok or not not_stuffed_reclaim or not risk_ok or failed_chase_block)
        string blocked_reason = "blocked"
        if not target_ok
            blocked_reason := "target room"
        else if not not_stuffed_reclaim
            if not close_cleared_level
                blocked_reason := "close not clear"
            else if reclaim_close_location < min_reclaim_close_location
                blocked_reason := "weak close"
            else if reclaim_upper_wick > max_reclaim_upper_wick_points
                blocked_reason := "upper wick"
            else
                blocked_reason := "pivot ribbon"
        else if not risk_ok
            blocked_reason := "risk " + str.tostring(candidate_risk_points, format.mintick)
        else if failed_chase_block
            blocked_reason := "failed cooldown"
        raw_flush_signal := raw_flush_signal or flush_event
        raw_reclaim_signal := raw_reclaim_signal or reclaim_event
        blocked_signal := blocked_signal or blocked_here
        watch_signal := watch_signal or watch_here
        armed_signal := armed_signal or armed_here
        paper_signal := paper_signal or paper_here
        invalidated_signal := invalidated_signal or invalid_here
        if blocked_here and str.length(active_block_reason) == 0
            active_block_reason := blocked_reason + " @ " + str.tostring(level, format.mintick)
        if paper_here and na(paper_level)
            paper_level := level
            paper_entry := candidate_entry
            paper_stop := candidate_stop
            paper_tp1 := candidate_tp1
            paper_tp2 := candidate_tp2
            paper_fresh_retest := fresh_level_retest
            paper_failed_chase_block := failed_chase_block
        else if paper_here and level > paper_level
            paper_level := level
            paper_entry := candidate_entry
            paper_stop := candidate_stop
            paper_tp1 := candidate_tp1
            paper_tp2 := candidate_tp2
            paper_fresh_retest := fresh_level_retest
            paper_failed_chase_block := failed_chase_block
        if armed_here and na(armed_level)
            armed_level := level
            armed_entry := candidate_entry
            armed_stop := candidate_stop
            armed_tp1 := candidate_tp1
            armed_tp2 := candidate_tp2
        else if armed_here and level > armed_level
            armed_level := level
            armed_entry := candidate_entry
            armed_stop := candidate_stop
            armed_tp1 := candidate_tp1
            armed_tp2 := candidate_tp2
        if watch_here and na(watch_level)
            watch_level := level
            watch_entry := candidate_entry
            watch_stop := candidate_stop
            watch_tp1 := candidate_tp1
            watch_tp2 := candidate_tp2
        else if watch_here and level > watch_level
            watch_level := level
            watch_entry := candidate_entry
            watch_stop := candidate_stop
            watch_tp1 := candidate_tp1
            watch_tp2 := candidate_tp2

if not na(paper_level)
    active_level := paper_level
    active_entry := paper_entry
    active_stop := paper_stop
    active_tp1 := paper_tp1
    active_tp2 := paper_tp2
else if not na(armed_level)
    active_level := armed_level
    active_entry := armed_entry
    active_stop := armed_stop
    active_tp1 := armed_tp1
    active_tp2 := armed_tp2
else if not na(watch_level)
    active_level := watch_level
    active_entry := watch_entry
    active_stop := watch_stop
    active_tp1 := watch_tp1
    active_tp2 := watch_tp2

bool watch_event = watch_signal and watch_signal[1] != true
bool armed_event = armed_signal and armed_signal[1] != true
bool paper_setup_now = paper_signal and not na(paper_level)
bool paper_edge_event = paper_setup_now and paper_signal[1] != true
bool paper_retest_reentry = paper_setup_now and paper_fresh_retest and not paper_failed_chase_block and not tracked_candidate_open and not na(last_candidate_closed_bar) and bar_index > last_candidate_closed_bar + reentry_cooldown_bars
bool paper_event = paper_edge_event or paper_retest_reentry
bool invalidated_event = invalidated_signal and invalidated_signal[1] != true
bool blocked_event = blocked_signal and blocked_signal[1] != true
bool candidate_level_changed = paper_setup_now and not paper_failed_chase_block and not tracked_candidate_open and not na(active_level) and not na(active_level[1]) and math.abs(active_level - active_level[1]) >= syminfo.mintick
bool long_candidate_event = paper_setup_now and not paper_failed_chase_block and not tracked_candidate_open and (paper_event or candidate_level_changed)
bool confirmed_signal_ok = not require_confirmed_signal_bar or barstate.isconfirmed
bool ltf_1m_has_data = array.size(ltf_1m_lows) > 0 and array.size(ltf_1m_highs) > 0
bool ltf_3m_has_data = array.size(ltf_3m_lows) > 0 and array.size(ltf_3m_highs) > 0
bool ltf_1m_entry_touched = entry_price_mode == "signal_close" ? true : f_ltf_touched(ltf_1m_lows, ltf_1m_highs, active_entry)
bool ltf_3m_entry_touched = entry_price_mode == "signal_close" ? true : f_ltf_touched(ltf_3m_lows, ltf_3m_highs, active_entry)
bool ltf_1m_stop_first = entry_price_mode == "signal_close" ? false : f_ltf_stop_before_tp1_after_entry(ltf_1m_lows, ltf_1m_highs, active_entry, active_stop, active_tp1)
bool ltf_3m_stop_first = entry_price_mode == "signal_close" ? false : f_ltf_stop_before_tp1_after_entry(ltf_3m_lows, ltf_3m_highs, active_entry, active_stop, active_tp1)
bool ltf_1m_ok = entry_price_mode == "signal_close" ? true : ltf_1m_has_data and ltf_1m_entry_touched and not ltf_1m_stop_first
bool ltf_3m_ok = entry_price_mode == "signal_close" ? true : ltf_3m_has_data and ltf_3m_entry_touched and not ltf_3m_stop_first
int ltf_1m_entry_index = ltf_1m_ok ? f_ltf_entry_index(ltf_1m_lows, ltf_1m_highs, active_entry, active_stop, active_tp1) : na
int ltf_3m_entry_index = ltf_3m_ok ? f_ltf_entry_index(ltf_3m_lows, ltf_3m_highs, active_entry, active_stop, active_tp1) : na
bool chart_5m_entry_touched = entry_price_mode == "signal_close" ? true : not na(active_entry) and low <= active_entry and high >= active_entry
bool chart_5m_stop_risk = entry_price_mode == "signal_close" ? false : chart_5m_entry_touched and not na(active_stop) and low <= active_stop and high >= active_stop
bool chart_5m_tp1_same_bar = entry_price_mode == "signal_close" ? false : chart_5m_entry_touched and not na(active_tp1) and high >= active_tp1
bool chart_5m_stop_first = chart_5m_stop_risk
bool chart_5m_ok = entry_price_mode == "signal_close" ? true : chart_5m_entry_touched and not chart_5m_stop_first
bool ltf_gate_disabled = ltf_fill_validation_mode == "off" or entry_price_mode == "signal_close"
bool ltf_gate_ok = ltf_gate_disabled ? true : ltf_fill_validation_mode == "1m" ? ltf_1m_ok : ltf_fill_validation_mode == "3m" ? ltf_3m_ok : ltf_fill_validation_mode == "5m_chart" ? chart_5m_ok : ltf_fill_validation_mode == "either_1m_or_3m" ? (ltf_1m_ok or ltf_3m_ok) : ltf_fill_validation_mode == "both_1m_and_3m" ? (ltf_1m_ok and ltf_3m_ok) : ltf_fill_validation_mode == "any_1m_3m_5m" ? (ltf_1m_ok or ltf_3m_ok or chart_5m_ok) : (ltf_1m_ok and ltf_3m_ok and chart_5m_ok)
bool ltf_mode_uses_1m = ltf_fill_validation_mode == "1m" or ltf_fill_validation_mode == "either_1m_or_3m" or ltf_fill_validation_mode == "both_1m_and_3m" or ltf_fill_validation_mode == "any_1m_3m_5m" or ltf_fill_validation_mode == "all_1m_3m_5m"
bool ltf_mode_uses_3m = ltf_fill_validation_mode == "3m" or ltf_fill_validation_mode == "either_1m_or_3m" or ltf_fill_validation_mode == "both_1m_and_3m" or ltf_fill_validation_mode == "any_1m_3m_5m" or ltf_fill_validation_mode == "all_1m_3m_5m"
bool ltf_mode_uses_5m = ltf_fill_validation_mode == "5m_chart" or ltf_fill_validation_mode == "any_1m_3m_5m" or ltf_fill_validation_mode == "all_1m_3m_5m"
int ltf_best_entry_time = na
string ltf_best_entry_source = "bar"
if ltf_mode_uses_1m and ltf_1m_ok and not na(ltf_1m_entry_index)
    ltf_best_entry_time := time + ltf_1m_entry_index * 60000
    ltf_best_entry_source := "1m"
if ltf_mode_uses_3m and ltf_3m_ok and not na(ltf_3m_entry_index)
    int candidate_3m_time = time + ltf_3m_entry_index * 180000
    if na(ltf_best_entry_time) or candidate_3m_time < ltf_best_entry_time
        ltf_best_entry_time := candidate_3m_time
        ltf_best_entry_source := "3m"
if ltf_mode_uses_5m and chart_5m_ok and na(ltf_best_entry_time)
    ltf_best_entry_time := na(time_close) ? time : time_close
    ltf_best_entry_source := "5m close"
string ltf_best_entry_time_text = na(ltf_best_entry_time) ? "bar " + f_et_time_from_timestamp(na(time_close) ? time : time_close) : ltf_best_entry_source + " " + f_et_time_from_timestamp(ltf_best_entry_time)
bool audited_long_event = confirmed_signal_ok and long_candidate_event
bool ltf_filtered_long_event = audited_long_event and ltf_enforcement_mode == "gate_alerts_and_accounting" and not ltf_gate_ok
bool trade_long_event = audited_long_event and (ltf_enforcement_mode == "audit_only" or ltf_gate_ok)
string ltf_1m_text = not ltf_1m_has_data ? "NODATA" : not ltf_1m_entry_touched ? "NOENTRY" : ltf_1m_stop_first ? "STOP1ST" : "OK"
string ltf_3m_text = not ltf_3m_has_data ? "NODATA" : not ltf_3m_entry_touched ? "NOENTRY" : ltf_3m_stop_first ? "STOP1ST" : "OK"
string chart_5m_text = not chart_5m_entry_touched ? "NOENTRY" : chart_5m_stop_risk and chart_5m_tp1_same_bar ? "MIXED_STOP" : chart_5m_stop_first ? "STOP1ST" : "OK"
string ltf_audit_text = "1m " + ltf_1m_text + " / 3m " + ltf_3m_text + " / 5m " + chart_5m_text

plotshape(show_raw_event_markers and raw_flush_signal, title="LUKE RAW FLUSH", text="FLUSH", style=shape.circle, location=location.belowbar, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)
plotshape(show_raw_event_markers and raw_reclaim_signal, title="LUKE RAW RECLAIM", text="RECLAIM", style=shape.circle, location=location.belowbar, color=color.new(color.blue, 0), textcolor=color.white, size=size.tiny)
plotshape(show_blocked_markers and blocked_event, title="LUKE BLOCKED", text="", style=shape.xcross, location=location.abovebar, color=color.new(color.orange, 0), textcolor=color.white, size=size.tiny)
plotshape(show_blocked_markers and ltf_filtered_long_event, title="LUKE LTF FILTERED", text="", style=shape.xcross, location=location.belowbar, color=color.new(color.orange, 0), textcolor=color.white, size=size.tiny)
plotshape(show_historical_signal_markers and watch_event, title="LUKE WATCH", text="", style=shape.circle, location=location.belowbar, color=color.new(color.gray, 0), textcolor=color.white, size=size.tiny)
plotshape(show_historical_signal_markers and armed_event, title="LUKE ARMED", text="", style=shape.triangleup, location=location.belowbar, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
plotshape(show_long_signal_marker and trade_long_event, title="LUKE LONG", text="LONG", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), textcolor=color.white, size=size.small)
plotshape(show_historical_signal_markers and invalidated_event, title="LUKE INVALIDATED", text="", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)

if blocked_event and show_blocked_reason_labels and str.length(active_block_reason) > 0
    f_add_status_label(status_labels, bar_index, high, "BLOCKED " + active_block_reason, color.new(color.orange, 0))

if trade_long_event and show_ltf_audit_labels
    color audit_color = ltf_gate_ok ? color.new(color.teal, 18) : color.new(color.orange, 12)
    f_add_status_label(status_labels, bar_index, candidate_label_y, "LTF " + ltf_audit_text, audit_color)

if ltf_filtered_long_event and not na(active_level)
    session_ltf_filtered += 1

if watch_event and not na(active_level)
    watch_id += 1
    session_watches += 1
    latest_watch_bar := bar_index
    latest_watch_level := active_level
    if show_watch_label
        f_add_watch_label(watch_labels, bar_index, low, "WATCH #" + str.tostring(watch_id) + " " + f_et_time_from_timestamp(na(time_close) ? time : time_close) + "\n" + str.tostring(active_level, format.mintick))
bool tracked_candidate_ended = false
if track_candidate_results and tracked_candidate_open and bar_index > tracked_candidate_start_bar
    bool tracked_hit_stop = low <= tracked_candidate_active_stop
    bool tracked_hit_tp1 = high >= tracked_candidate_tp1
    bool tracked_hit_tp2 = high >= tracked_candidate_tp2
    float accounting_entry = tracked_candidate_entry
    if single_contract_pnl and tracked_hit_stop and tracked_hit_tp1 and not tracked_candidate_tp1_hit
        float result_points = f_mixed_realized_points(tracked_candidate_active_stop, accounting_entry, tracked_candidate_tp1)
        float result_contracts = 1.0
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        session_mixed += 1
        if result_points > 0
            session_successes += 1
            tracked_candidate_success_counted := true
            session_tp1_hits += 1
        else if result_points < 0
            session_stopped += 1
            last_failed_candidate_bar := bar_index
            last_failed_candidate_level := tracked_candidate_level
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, (result_points > 0 ? "Result: TP1 mixed " : "Result: STOPPED mixed ") + f_money(tracked_candidate_trade_net_dollars), result_points > 0 ? color.new(color.green, 10) : color.new(color.red, 12))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
        tracked_candidate_ended := true
    else if single_contract_pnl and tracked_hit_tp1 and not tracked_candidate_tp1_hit
        float result_points = tracked_candidate_tp1 - accounting_entry
        float result_contracts = 1.0
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        session_successes += 1
        session_tp1_hits += 1
        tracked_candidate_success_counted := true
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, "Result: TP1 " + f_money(tracked_candidate_trade_net_dollars), color.new(color.green, 10))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
        tracked_candidate_ended := true
    else if tracked_hit_stop and tracked_hit_tp2 and not tracked_candidate_tp1_hit
        float result_contracts = mixed_bar_pnl_policy == "zero" ? 0.0 : f_open_contract_count(false)
        float stop_first_points = (tracked_candidate_active_stop - accounting_entry) * (split_contract_pnl ? 2.0 : 1.0)
        float target_first_points = split_contract_pnl ? (tracked_candidate_tp1 - accounting_entry) + (tracked_candidate_tp2 - accounting_entry) : tracked_candidate_tp2 - accounting_entry
        float result_points = mixed_bar_pnl_policy == "target_first" ? target_first_points : mixed_bar_pnl_policy == "zero" ? 0.0 : stop_first_points
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        session_mixed += 1
        if result_points > 0
            session_successes += 1
            tracked_candidate_success_counted := true
            session_tp2_hits += 1
        else if result_points < 0
            session_stopped += 1
            last_failed_candidate_bar := bar_index
            last_failed_candidate_level := tracked_candidate_level
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, (result_points > 0 ? "Result: TP2 mixed " : "Result: STOPPED mixed ") + f_money(tracked_candidate_trade_net_dollars), result_points > 0 ? color.new(color.green, 10) : color.new(color.red, 12))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
        tracked_candidate_ended := true
    else if tracked_hit_tp2
        float result_contracts = f_open_contract_count(tracked_candidate_tp1_hit)
        float result_points = split_contract_pnl and not tracked_candidate_tp1_hit ? (tracked_candidate_tp1 - accounting_entry) + (tracked_candidate_tp2 - accounting_entry) : tracked_candidate_tp2 - accounting_entry
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        if not tracked_candidate_success_counted
            session_successes += 1
            tracked_candidate_success_counted := true
        session_tp2_hits += 1
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, "Result: TP2 " + f_money(tracked_candidate_trade_net_dollars), color.new(color.green, 8))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
        tracked_candidate_ended := true
    else if tracked_hit_stop and tracked_candidate_tp1_hit
        float result_contracts = f_open_contract_count(true)
        float result_points = tracked_candidate_active_stop - accounting_entry
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        session_breakevens += 1
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, "Result: TP1 + BE " + f_money(tracked_candidate_trade_net_dollars), color.new(color.teal, 10))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
        tracked_candidate_ended := true
    else if tracked_hit_stop and tracked_hit_tp1
        float result_contracts = f_mixed_tp1_contract_count()
        float stop_first_points = (tracked_candidate_active_stop - accounting_entry) * (split_contract_pnl ? 2.0 : 1.0)
        float target_first_points = split_contract_pnl ? tracked_candidate_tp1 - accounting_entry : 0.0
        float result_points = mixed_bar_pnl_policy == "target_first" ? target_first_points : mixed_bar_pnl_policy == "zero" ? 0.0 : stop_first_points
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        if result_points > 0 and not tracked_candidate_success_counted
            session_successes += 1
            tracked_candidate_success_counted := true
            session_tp1_hits += 1
        else if result_points < 0
            session_stopped += 1
            last_failed_candidate_bar := bar_index
            last_failed_candidate_level := tracked_candidate_level
        session_mixed += 1
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, (result_points > 0 ? "Result: TP1 mixed " : "Result: STOPPED mixed ") + f_money(tracked_candidate_trade_net_dollars), result_points > 0 ? color.new(color.green, 10) : color.new(color.red, 12))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
        tracked_candidate_ended := true
    else if tracked_hit_stop
        float result_contracts = f_open_contract_count(tracked_candidate_tp1_hit)
        float result_points = (tracked_candidate_active_stop - accounting_entry) * result_contracts
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        session_stopped += 1
        last_failed_candidate_bar := bar_index
        last_failed_candidate_level := tracked_candidate_level
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, "Result: STOPPED " + f_money(tracked_candidate_trade_net_dollars), color.new(color.red, 12))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
        tracked_candidate_ended := true
    else if tracked_hit_tp1 and not tracked_candidate_tp1_hit
        tracked_candidate_tp1_hit := true
        if not tracked_candidate_success_counted
            session_successes += 1
            tracked_candidate_success_counted := true
        session_tp1_hits += 1
        float result_contracts = f_tp1_partial_contract_count()
        float result_points = split_contract_pnl ? tracked_candidate_tp1 - accounting_entry : 0.0
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        tracked_candidate_active_stop := tracked_candidate_entry
        if not na(stop_line)
            line.set_y1(stop_line, tracked_candidate_active_stop)
            line.set_y2(stop_line, tracked_candidate_active_stop)
            line.set_color(stop_line, color.new(color.yellow, 0))
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, "Status: TP1 banked " + f_money(tracked_candidate_trade_net_dollars) + " / runner BE", color.new(color.teal, 12))
if trade_long_event and not na(active_level)
    if track_candidate_results and tracked_candidate_open and not tracked_candidate_ended
        session_refreshed += 1
        float result_contracts = f_open_contract_count(tracked_candidate_tp1_hit)
        float result_points = (close - tracked_candidate_entry) * result_contracts
        float event_net_dollars = f_event_net_dollars(result_points, result_contracts)
        session_realized_points += result_points
        session_realized_dollars += result_points * pnl_dollars_per_point
        session_cost_dollars += f_event_cost_dollars(result_contracts)
        session_net_dollars += event_net_dollars
        tracked_candidate_trade_net_dollars += event_net_dollars
        f_update_entry_signal_label(tracked_candidate_entry_label, tracked_candidate_entry_text, "Result: REFRESHED " + f_money(tracked_candidate_trade_net_dollars), color.new(color.gray, 18))
        tracked_candidate_open := false
        last_candidate_closed_bar := bar_index
    if not na(entry_line)
        line.delete(entry_line)
    if not na(stop_line)
        line.delete(stop_line)
    if not na(tp1_line)
        line.delete(tp1_line)
    if not na(tp2_line)
        line.delete(tp2_line)
    candidate_id += 1
    session_attempts += 1
    tracked_candidate_open := track_candidate_results
    tracked_candidate_tp1_hit := false
    tracked_candidate_success_counted := false
    tracked_candidate_id := candidate_id
    tracked_candidate_start_bar := bar_index
    tracked_candidate_level := active_level
    tracked_candidate_entry := active_entry
    tracked_candidate_stop := active_stop
    tracked_candidate_active_stop := active_stop
    tracked_candidate_tp1 := active_tp1
    tracked_candidate_tp2 := active_tp2
    tracked_candidate_entry_label := na
    tracked_candidate_entry_text := ""
    tracked_candidate_trade_net_dollars := 0.0
    string program_context = show_program_context ? "\nmode " + account_mode + " / " + size_mode + " / acct " + realistic_accounting_mode : ""
    string watch_context = not na(latest_watch_bar) ? "\nwatch #" + str.tostring(watch_id) + " @ " + str.tostring(latest_watch_level, format.mintick) : ""
    string details = "LONG #" + str.tostring(candidate_id) + " " + ltf_best_entry_time_text + " cluster " + str.tostring(active_level, format.mintick) + watch_context + program_context + "\n" + ltf_audit_text + "\nE " + str.tostring(active_entry, format.mintick) + " / acct fill " + str.tostring(f_accounting_entry(active_entry), format.mintick) + "\nS " + str.tostring(active_stop, format.mintick) + " / T1 " + str.tostring(active_tp1, format.mintick) + " / T2 " + str.tostring(active_tp2, format.mintick)
    tracked_candidate_entry_text := details
    if signal_timing_mode == "live_intrabar" and not barstate.isconfirmed
        live_pending_long := true
        live_pending_bar := bar_index
        live_pending_text := details
        live_pending_y := candidate_label_y
        live_pending_level := active_level
        live_pending_entry := active_entry
        live_pending_label := na
    if show_bracket_visual
        entry_line := line.new(bar_index, active_entry, bar_index + bracket_bars, active_entry, color=color.new(color.white, 0), width=2)
        stop_line := line.new(bar_index, active_stop, bar_index + bracket_bars, active_stop, color=color.new(color.red, 0), width=2)
        tp1_line := line.new(bar_index, active_tp1, bar_index + bracket_bars, active_tp1, color=color.new(color.green, 0), width=2)
        tp2_line := line.new(bar_index, active_tp2, bar_index + bracket_bars, active_tp2, color=color.new(color.lime, 0), width=2)
    if show_latest_candidate_label
        label new_entry_label = f_add_entry_signal_label(entry_signal_labels, bar_index, candidate_label_y, details + "\nStatus: open")
        tracked_candidate_entry_label := new_entry_label
        if signal_timing_mode == "live_intrabar" and live_pending_long and live_pending_bar == bar_index
            live_pending_label := new_entry_label

bool live_cancel_now = signal_timing_mode == "live_intrabar" and live_pending_long and live_pending_bar == bar_index and not trade_long_event
if live_cancel_now
    bool cancel_area_still_active = na(live_pending_level) or na(live_pending_entry) ? true : low <= live_pending_entry and high >= live_pending_level - syminfo.mintick
    session_live_cancelled += 1
    live_cancelled_this_bar := true
    live_cancelled_bar := bar_index
    live_cancelled_text := str.length(live_pending_text) > 0 ? live_pending_text + "\nStatus: CANCELLED live - can refire" : "LONG cancelled live - can refire"
    live_cancelled_y := na(live_pending_y) ? candidate_label_y : live_pending_y
    live_cancelled_label := live_pending_label
    array.push(live_cancelled_texts, live_cancelled_text)
    array.push(live_cancelled_ys, live_cancelled_y)
    if show_cancel_watch_label and cancel_area_still_active
        string cancel_watch_text = "CXL WATCH\n" + (na(live_pending_level) ? "" : str.tostring(live_pending_level, format.mintick)) + "\ncan refire"
        f_add_cancel_watch_label(watch_labels, bar_index, low, cancel_watch_text)
    tracked_candidate_open := false
    tracked_candidate_tp1_hit := false
    tracked_candidate_success_counted := false
    live_pending_long := false
    live_pending_bar := na
    live_pending_text := ""
    live_pending_y := na
    live_pending_level := na
    live_pending_entry := na
    live_pending_label := na

if signal_timing_mode == "live_intrabar" and live_cancelled_this_bar and live_cancelled_bar == bar_index and show_latest_candidate_label and array.size(live_cancelled_texts) > 0
    for cancel_i = 0 to array.size(live_cancelled_texts) - 1
        label cancelled_label = f_add_entry_signal_label(entry_signal_labels, bar_index, array.get(live_cancelled_ys, cancel_i), array.get(live_cancelled_texts, cancel_i))
        label.set_color(cancelled_label, color.new(color.orange, 12))

if signal_timing_mode == "live_intrabar" and barstate.isconfirmed and live_pending_long and live_pending_bar == bar_index
    live_pending_long := false
    live_pending_bar := na
    live_pending_text := ""
    live_pending_y := na
    live_pending_level := na
    live_pending_entry := na
    live_pending_label := na

if barstate.islast
    if show_session_scorecard
        int total_signal_attempts = session_attempts + session_live_cancelled
        int total_signal_misses = session_stopped + session_live_cancelled
        float cancel_min_commission = session_live_cancelled * commission_per_contract_round_trip * f_open_contract_count(false)
        string score_text = str.tostring(session_successes) + "/" + str.tostring(total_signal_attempts)
        float score_pct = total_signal_attempts > 0 ? (session_successes * 100.0) / total_signal_attempts : na
        string score_pct_text = na(score_pct) ? "n/a" : str.tostring(score_pct, "#.0") + "%"
        string realized_text = show_session_pnl ? f_signed_points(session_realized_points) : ""
        string realized_money_text = show_session_pnl ? f_money(session_realized_dollars) : ""
        float session_commission_dollars = f_session_commission_dollars()
        float session_slippage_dollars = f_session_slippage_dollars()
        float session_after_commissions = session_realized_dollars - session_commission_dollars
        float session_after_all_costs = session_net_dollars
        string after_commission_text = show_session_pnl ? f_money(session_after_commissions) : ""
        string after_all_text = show_session_pnl ? f_money(session_after_all_costs) : ""
        string eval_text = eval_loss_limit_dollars > 0 and session_net_dollars <= -eval_loss_limit_dollars ? " BREACH" : ""
        string counts_text = "W " + str.tostring(session_watches) + " / L " + str.tostring(session_attempts) + " / C " + str.tostring(session_live_cancelled)
        string miss_text = str.tostring(total_signal_misses) + " = S " + str.tostring(session_stopped) + " + C " + str.tostring(session_live_cancelled)
        string milestone_text = "T1 " + str.tostring(session_tp1_hits) + " / T2 " + str.tostring(session_tp2_hits) + " / BE " + str.tostring(session_breakevens) + " / M " + str.tostring(session_mixed)
        string cost_text = "comm " + f_money(session_commission_dollars) + " / slip " + f_money(session_slippage_dollars)
        string enforcement_text = ltf_enforcement_mode == "audit_only" ? "audit" : "gated"
        string timing_text = signal_timing_mode == "live_intrabar" ? "live" : "confirmed"
        table.cell(session_scorecard, 0, 0, "Luke best UI", text_color=color.white, bgcolor=color.new(color.black, 10), text_size=size.small)
        table.cell(session_scorecard, 1, 0, ltf_fill_validation_mode + " " + enforcement_text + " " + timing_text, text_color=color.white, bgcolor=color.new(color.black, 10), text_size=size.small)
        table.cell(session_scorecard, 0, 1, "score incl cxl", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 1, score_text + "  " + score_pct_text, text_color=session_successes > 0 ? color.lime : color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 2, "watch/long/cxl", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 2, counts_text, text_color=session_live_cancelled > 0 ? color.orange : color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 3, "misses incl cxl", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 3, miss_text, text_color=total_signal_misses > 0 ? color.red : color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 4, "milestones", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 4, milestone_text, text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 5, "gross total", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 5, realized_text + "  " + realized_money_text, text_color=session_realized_points >= 0 ? color.lime : color.red, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 6, "minus comm", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 6, after_commission_text, text_color=session_after_commissions >= 0 ? color.lime : color.red, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 7, "realistic net", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 7, after_all_text + eval_text, text_color=session_after_all_costs >= 0 ? color.lime : color.red, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 8, "cxl min comm", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 8, f_money(cancel_min_commission), text_color=session_live_cancelled > 0 ? color.orange : color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 9, "mode/costs", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 9, realistic_accounting_mode + " | " + cost_text, text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 10, "base lines", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 10, "M blue | S lime | both yellow", text_color=color.yellow, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 11, "mancini ctx", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 11, "major aqua | focus orange | trigger pink", text_color=color.orange, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 0, 12, "mancini ctx", text_color=color.silver, bgcolor=color.new(color.black, 45), text_size=size.small)
        table.cell(session_scorecard, 1, 12, "target purple | read gray", text_color=color.purple, bgcolor=color.new(color.black, 45), text_size=size.small)
    else
        for panel_row = 0 to 12
            table.cell(session_scorecard, 0, panel_row, "", bgcolor=color.new(color.black, 100))
            table.cell(session_scorecard, 1, panel_row, "", bgcolor=color.new(color.black, 100))

alertcondition(enable_alertconditions and alert_watch_events and watch_event, "LUKE WATCH", "LUKE WATCHLIST ONLY - not an order - WATCH level condition")
alertcondition(enable_alertconditions and alert_armed_events and armed_event, "LUKE ARMED", "LUKE WATCHLIST ONLY - not an order - ARMED reclaim condition")
alertcondition(enable_alertconditions and alert_paper_candidate_events and trade_long_event, "LUKE LONG", "LUKE WATCHLIST ONLY - not an order - LTF-audited LONG condition")
alertcondition(enable_alertconditions and alert_invalidated_events and invalidated_event, "LUKE INVALIDATED", "LUKE WATCHLIST ONLY - not an order - INVALIDATED reclaim condition")
alertcondition(enable_alertconditions and alert_blocked_events and blocked_event, "LUKE BLOCKED", "LUKE WATCHLIST ONLY - not an order - reclaim sequence blocked by target/risk/freshness gate")
